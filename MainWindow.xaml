                                        <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="📊 Results" FontWeight="SemiBold" Foreground="#A78BFA" FontSize="12" VerticalAlignment="Top"/>
                                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap">Results grid shows each call with status, timing, and size. Summary KPIs show total/pass/fail and p95 latency. Export to CSV for reporting.</TextBlock>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ══════════════════════════════════════════════════
                                 SECTION D — Original Payrix / Webhook reference
                                 ══════════════════════════════════════════════════ -->
                            <TextBlock Text="⚡  Payrix Webhook &amp; Transaction Reference" FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,10"/>

                            <!-- Section 1: Webhook Types -->
