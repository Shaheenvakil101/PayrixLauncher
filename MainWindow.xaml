                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Withdrawal" FontWeight="SemiBold" Foreground="#FB923C" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" Text="Disbursement/payout transferred out to the merchant's bank account." FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Section 2: Transaction Statuses -->
                            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="22,18" Margin="0,0,0,14" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,12,0">
                                            <Border.Background><SolidColorBrush Color="#4F46E5" Opacity="0.2"/></Border.Background>
                                            <TextBlock Text="📊" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Transaction Statuses" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,0,0,14"/>
                                    <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="1" FontWeight="Bold" Foreground="#FBBF24" FontSize="13"/><TextBlock Grid.Column="1" Text="Pending" FontWeight="SemiBold" Foreground="#FBBF24" FontSize="12.5"/><TextBlock Grid.Column="2" Text="Authorization pending — not yet captured or settled." FontSize="12" Foreground="{DynamicResource SubText}"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="2" FontWeight="Bold" Foreground="#F87171" FontSize="13"/><TextBlock Grid.Column="1" Text="Declined" FontWeight="SemiBold" Foreground="#F87171" FontSize="12.5"/><TextBlock Grid.Column="2" Text="Transaction was declined by card network or bank." FontSize="12" Foreground="{DynamicResource SubText}"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="3" FontWeight="Bold" Foreground="#818CF8" FontSize="13"/><TextBlock Grid.Column="1" Text="Captured" FontWeight="SemiBold" Foreground="#818CF8" FontSize="12.5"/><TextBlock Grid.Column="2" Text="Authorized and captured — ready for settlement batch." FontSize="12" Foreground="{DynamicResource SubText}"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="4" FontWeight="Bold" Foreground="#34D399" FontSize="13"/><TextBlock Grid.Column="1" Text="Settled (ACH)" FontWeight="SemiBold" Foreground="#34D399" FontSize="12.5"/><TextBlock Grid.Column="2" Text="ACH transaction fully settled. For cards, status 4 = Error." FontSize="12" Foreground="{DynamicResource SubText}"/>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="5" FontWeight="Bold" Foreground="#FB923C" FontSize="13"/><TextBlock Grid.Column="1" Text="Returned" FontWeight="SemiBold" Foreground="#FB923C" FontSize="12.5"/><TextBlock Grid.Column="2" Text="ACH payment returned by the receiving bank (e.g. insufficient funds)." FontSize="12" Foreground="{DynamicResource SubText}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Section 3: Transaction Types -->
                            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="22,18" Margin="0,0,0,14" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,12,0">
                                            <Border.Background><SolidColorBrush Color="#0EA5E9" Opacity="0.2"/></Border.Background>
                                            <TextBlock Text="⇅" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#38BDF8"/>
                                        </Border>
                                        <TextBlock Text="Transaction Types" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,0,0,14"/>
                                    <UniformGrid Columns="2" Margin="0,0,0,0">
                                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="1" FontWeight="Bold" Foreground="#38BDF8" FontSize="13"/><TextBlock Grid.Column="1" Text="Sale / Auth+Capture" FontSize="12" Foreground="{DynamicResource SubText}"/></Grid>
                                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="2" FontWeight="Bold" Foreground="#38BDF8" FontSize="13"/><TextBlock Grid.Column="1" Text="Authorization only" FontSize="12" Foreground="{DynamicResource SubText}"/></Grid>
                                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="3" FontWeight="Bold" Foreground="#38BDF8" FontSize="13"/><TextBlock Grid.Column="1" Text="Capture (prior auth)" FontSize="12" Foreground="{DynamicResource SubText}"/></Grid>
                                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="5" FontWeight="Bold" Foreground="#38BDF8" FontSize="13"/><TextBlock Grid.Column="1" Text="Refund / Credit" FontSize="12" Foreground="{DynamicResource SubText}"/></Grid>
                                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="6" FontWeight="Bold" Foreground="#FB923C" FontSize="13"/><TextBlock Grid.Column="1" Text="Disbursement" FontSize="12" Foreground="{DynamicResource SubText}"/></Grid>
                                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="7" FontWeight="Bold" Foreground="#A78BFA" FontSize="13"/><TextBlock Grid.Column="1" Text="ACH Debit (pull)" FontSize="12" Foreground="{DynamicResource SubText}"/></Grid>
                                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="8" FontWeight="Bold" Foreground="#A78BFA" FontSize="13"/><TextBlock Grid.Column="1" Text="ACH Credit (push)" FontSize="12" Foreground="{DynamicResource SubText}"/></Grid>
                                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="9" FontWeight="Bold" Foreground="#4ADE80" FontSize="13"/><TextBlock Grid.Column="1" Text="Void" FontSize="12" Foreground="{DynamicResource SubText}"/></Grid>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <!-- Section 4: ACH / Card Flows -->
                            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="22,18" Margin="0,0,0,14" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,12,0">
                                            <Border.Background><SolidColorBrush Color="#7C3AED" Opacity="0.2"/></Border.Background>
                                            <TextBlock Text="⇄" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#A78BFA"/>
                                        </Border>
                                        <TextBlock Text="ACH / Card Payment Flows" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,0,0,14"/>
                                    <Grid Margin="0,0,20,12"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="ACH Flow" FontWeight="SemiBold" Foreground="#A78BFA" FontSize="12.5" VerticalAlignment="Top"/>
                                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap">Customer submits bank account → Payrix initiates NACHA file → Bank processes (1–3 business days) → Status: Pending → Settled (4) or Returned (5). Use webhook type ACH Return to test return scenarios.</TextBlock>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Card Flow" FontWeight="SemiBold" Foreground="#38BDF8" FontSize="12.5" VerticalAlignment="Top"/>
                                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap">Customer submits card → Auth request to card network (Visa/MC) → Capture triggers settlement batch → Status: Pending (1) → Captured (3) → Settled. Refunds create a new transaction (type 5) linked via Fortxn.</TextBlock>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Section 5: Testing Instructions -->
                            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="22,18" Margin="0,0,0,14" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,12,0">
                                            <Border.Background><SolidColorBrush Color="#FBBF24" Opacity="0.2"/></Border.Background>
                                            <TextBlock Text="🧪" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Testing Instructions" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,0,0,14"/>
                                    <StackPanel>
                                        <TextBlock FontSize="12.5" Foreground="{DynamicResource PrimaryText}" FontWeight="SemiBold" Margin="0,0,0,6">Webhook Test Setup:</TextBlock>
                                        <TextBlock FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap" Margin="0,0,0,10">1. Navigate to Webhook Tests tab and configure the target URL (Local/Staging/Sprint).&#x0a;2. Set the Entity Custom field: AccountID,CompanyID (use Fetch from DB button to auto-populate).&#x0a;3. Select the webhook type (ACH Return, ACH Refund, Card Refund, Settlement, Withdrawal).&#x0a;4. Fill in the Transaction ID and Amount fields.&#x0a;5. Click Run to send the POST and view the response.</TextBlock>
                                        <TextBlock FontSize="12.5" Foreground="{DynamicResource PrimaryText}" FontWeight="SemiBold" Margin="0,6,0,6">Sandbox Credentials:</TextBlock>
                                        <Border Background="{DynamicResource DbConfigBg}" CornerRadius="8" Padding="14,10" BorderBrush="{DynamicResource DbConfigBorder}" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock FontSize="11.5" Foreground="{DynamicResource SubText}"><Run FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}">API:</Run>  test.api.payrix.com</TextBlock>
                                                <TextBlock FontSize="11.5" Foreground="{DynamicResource SubText}" Margin="0,4,0,0"><Run FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}">Portal:</Run>  test-portal.payrix.com</TextBlock>
                                                <TextBlock FontSize="11.5" Foreground="{DynamicResource SubText}" Margin="0,4,0,0"><Run FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}">Test Card:</Run>  4111 1111 1111 1111  Exp: 12/26  CVV: 999</TextBlock>
                                                <TextBlock FontSize="11.5" Foreground="{DynamicResource SubText}" Margin="0,4,0,0"><Run FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}">Test ACH:</Run>  Routing: 021000021  Account: 9900000002</TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Section 6: QA / Dev Guide -->
                            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="22,18" Margin="0,0,0,0" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,12,0">
                                            <Border.Background><SolidColorBrush Color="#F87171" Opacity="0.2"/></Border.Background>
                                            <TextBlock Text="🛠" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Internal QA / Dev Guide" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,0,0,14"/>
                                    <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Find CompanyID" FontWeight="SemiBold" Foreground="#F87171" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap">Enter a Payrix transaction ID in the DB Config panel → click Fetch. Queries ServiceEntity → Company in the payment-service DB.</TextBlock>
                                    </Grid>
                                    <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Find AccountID" FontWeight="SemiBold" Foreground="#F87171" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap">Enter the user email in the Email field → click ▶ Fetch button next to it. Queries Account.Email in the BQECoreHost main DB.</TextBlock>
                                    </Grid>
                                    <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Decrypt IDs" FontWeight="SemiBold" Foreground="#F87171" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap">Use Crypto tab to decode encrypted AccountID/CompanyID tokens from BQE Core URLs or webhook payloads.</TextBlock>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Discrepancies" FontWeight="SemiBold" Foreground="#F87171" FontSize="12.5"/>
