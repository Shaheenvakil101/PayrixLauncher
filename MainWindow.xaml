<Window x:Class="PayrixLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PayrixLauncher.Models"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="BQE Core — ePayment Tools" Height="960" Width="1250"
        MinWidth="800" MinHeight="600"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/app.ico"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        Background="{DynamicResource WindowBg}">

    <Window.Resources>
        <!-- Implicit TextBlock — Apple SF Pro fallback, theme-aware foreground -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, Inter"/>
        </Style>

        <!-- Shared right-click context menu for DataGrids -->
        <ContextMenu x:Key="GridContextMenu">
            <MenuItem Header="📋  Copy Cell Value"  Click="CtxCopyCell_Click"  InputGestureText="Ctrl+C"/>
            <MenuItem Header="📄  Copy Row"         Click="CtxCopyRow_Click"/>
            <Separator/>
            <MenuItem Header="⎘   Copy All Rows"    Click="CtxCopyAll_Click"/>
            <Separator/>
            <MenuItem Header="🔍  Search This Value" Click="CtxSearchValue_Click"/>
        </ContextMenu>

        <!-- Shared right-click context menu for TextBoxes -->
        <ContextMenu x:Key="TextBoxContextMenu">
            <MenuItem Header="📋  Copy"        Command="ApplicationCommands.Copy"/>
            <MenuItem Header="✂️  Cut"         Command="ApplicationCommands.Cut"/>
            <MenuItem Header="📌  Paste"       Command="ApplicationCommands.Paste"/>
            <Separator/>
            <MenuItem Header="☰   Select All"  Command="ApplicationCommands.SelectAll"/>
            <Separator/>
            <MenuItem Header="🗑️  Clear"       Click="CtxClearTextBox_Click"/>
        </ContextMenu>

        <!-- Implicit TextBox — Apple-style, DynamicResource colors, 10px radius -->
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource InputFg}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource InputFg}"/>
            <Setter Property="SelectionBrush"  Value="{DynamicResource TabSelectedBorder}"/>
            <Setter Property="ContextMenu"     Value="{StaticResource TextBoxContextMenu}"/>
            <Setter Property="FontFamily"      Value="Segoe UI Variable Text, Segoe UI, Inter"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          CanContentScroll="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource TabSelectedBorder}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource SubText}"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SearchCardBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SubText}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Implicit Button — Apple filled, DynamicResource, 10px radius -->
        <Style TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource DarkBtnBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource DarkText}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource DarkBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Segoe UI Variable Text, Segoe UI, Inter"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PrimaryButton — Apple Blue #007AFF with glow, 10px radius, SemiBold, Height=36 -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#007AFF"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI Variable Text, Segoe UI, Inter"/>
            <Setter Property="Padding"         Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.25" Color="#007AFF"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0066DD"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SortHeaderButton — flat table-header sort button -->
        <Style x:Key="SortHeaderButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource SubText}"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontFamily"      Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TabHoverBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SecondaryButton — Apple Green #34C759 -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#34C759"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.25" Color="#34C759"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#28A745"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DangerButton — Apple Red #FF3B30 -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#FF3B30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.25" Color="#FF3B30"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D62D22"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card — Apple card, 14px radius, subtle shadow -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource CardBg}"/>
            <Setter Property="CornerRadius"    Value="14"/>
            <Setter Property="Padding"         Value="20"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.08"
                                      Color="{DynamicResource CardShadowColor}"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- NavBtn — sidebar nav, responds to DynamicResource SidebarNavFg, 10px radius -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="Foreground"                 Value="{DynamicResource SidebarNavFg}"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding"                    Value="14,10"/>
            <Setter Property="Margin"                     Value="0,1"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFFFFF18"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFFFFF28"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- NavBtnActive — Apple blue gradient, white text -->
        <Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#007AFF" Offset="0"/>
                        <GradientStop Color="#5856D6" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Root Grid — Sidebar + Main content -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             SIDEBAR
             ══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBg}"
                BorderBrush="{DynamicResource SidebarBorder}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Logo -->
                    <RowDefinition Height="*"/>      <!-- Nav items -->
                    <RowDefinition Height="Auto"/>   <!-- User profile -->
                </Grid.RowDefinitions>

                <!-- Logo area -->
                <Border Grid.Row="0" Padding="20,22,20,18"
                        BorderBrush="#FFFFFF18" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="10"
                                Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1565C0" Offset="0"/>
                                    <GradientStop Color="#0D47A1" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="C" FontSize="18" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="White"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="BQE Core" FontSize="14" FontWeight="SemiBold"
                                       Foreground="White"/>
                            <TextBlock Text="ePayment Tools" FontSize="10" Foreground="#90CAF9"
                                       Margin="0,1,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Nav items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="10,14,10,0">
                    <ScrollViewer.Resources>
                        <!-- Always-dark thumb — overrides whatever theme is active -->
                        <Style x:Key="SidebarThumb" TargetType="Thumb">
                            <Setter Property="OverridesDefaultStyle" Value="True"/>
                            <Setter Property="IsTabStop"             Value="False"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border x:Name="Bd" Background="#AEAEB2" CornerRadius="3"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#6E6E73"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style x:Key="SidebarPageBtn" TargetType="RepeatButton">
                            <Setter Property="OverridesDefaultStyle" Value="True"/>
                            <Setter Property="IsTabStop"             Value="False"/>
                            <Setter Property="Focusable"             Value="False"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="RepeatButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="ScrollBar">
                            <Setter Property="OverridesDefaultStyle"  Value="True"/>
                            <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
                            <Style.Triggers>
                                <Trigger Property="Orientation" Value="Vertical">
                                    <Setter Property="Width"    Value="4"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ScrollBar">
                                                <Border Background="Transparent" Width="4" Padding="1,4">
                                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                        <Track.DecreaseRepeatButton>
                                                            <RepeatButton Style="{StaticResource SidebarPageBtn}" Command="ScrollBar.PageUpCommand"/>
                                                        </Track.DecreaseRepeatButton>
                                                        <Track.Thumb>
                                                            <Thumb Style="{StaticResource SidebarThumb}"/>
                                                        </Track.Thumb>
                                                        <Track.IncreaseRepeatButton>
                                                            <RepeatButton Style="{StaticResource SidebarPageBtn}" Command="ScrollBar.PageDownCommand"/>
                                                        </Track.IncreaseRepeatButton>
                                                    </Track>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Resources>
                    <StackPanel>

                        <!-- Tab 0: Transaction Viewer -->
                        <Button x:Name="NavTxnViewer" Tag="0"
                                Style="{StaticResource NavBtnActive}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗂" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Transaction Viewer" FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <!-- Tab NEW: Dashboard -->
                        <Button x:Name="NavDashboard" Tag="11"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏠" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Dashboard" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <!-- Tab 1: Transactions -->
                        <Button x:Name="NavTxn" Tag="1"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⊞" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Transactions" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <!-- Tab NEW: Disbursements -->
                        <Button x:Name="NavDisbursements" Tag="12"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💳" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Disbursements" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <!-- Tab 3: Webhooks -->
                        <Button x:Name="NavWebhooks" Tag="4"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚡" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Webhooks" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <!-- Tab NEW: Accounts -->
                        <Button x:Name="NavAccounts" Tag="13"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏦" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Accounts" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <!-- Tab NEW: Merchants -->
                        <Button x:Name="NavMerchants" Tag="14"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏪" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Merchants" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <!-- Tab NEW: Reports -->
                        <Button x:Name="NavReports" Tag="15"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Reports" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <!-- Divider -->
                        <Border Height="1" Background="#FFFFFF12" Margin="4,10"/>

                        <!-- Tab 8: Settings -->
                        <Button x:Name="NavSettings" Tag="9"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Settings" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <!-- Tab 5: API Tools -->
                        <Button x:Name="NavJsonTools" Tag="6"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔧" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="API Tools" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <!-- Tab 15: HTTP Client -->
                        <Button x:Name="NavHttpClient" Tag="16"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📡" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="HTTP Client" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <!-- Tab 16: Performance -->
                        <Button x:Name="NavPerf" Tag="17"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚡" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Performance" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <!-- Tab 9: Help & Docs -->
                        <Button x:Name="NavHelp" Tag="10"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="❓" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Help &amp; Docs" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <!-- Tab 17: Core DB Utility -->
                        <Button x:Name="NavCoreDb" Tag="18"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗄" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Core DB" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>

                <!-- User profile + Logout -->
                <Border Grid.Row="2" Padding="12,12"
                        BorderBrush="#FFFFFF18" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar + name -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="34" Height="34" CornerRadius="17" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C3AED" Offset="0"/>
                                        <GradientStop Color="#4F46E5" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock x:Name="SidebarAvatarText" Text="S" FontSize="14" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="SidebarUserName" Text="Shaheen" FontSize="12.5" FontWeight="SemiBold"
                                           Foreground="#E2E0FF"/>
                                <TextBlock x:Name="SidebarUserRole" Text="Administrator" FontSize="10.5"
                                           Foreground="#64648A"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Logout button -->
                        <Border Grid.Column="1" Width="30" Height="30" CornerRadius="8"
                                Background="Transparent" Cursor="Hand"
                                ToolTip="Sign out"
                                MouseLeftButtonDown="LogoutBtn_Click"
                                VerticalAlignment="Center" Margin="6,0,0,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFFFFF18"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="⏻" FontSize="14" Foreground="#64648A"
                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#F87171"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             MAIN CONTENT
             ══════════════════════════════════════════════════════════ -->
        <!-- DockPanel root — upper content stacks at top, footer pins at bottom,
             tabs card fills all remaining space so the DataGrid scrolls within
             its own space (no double scrollbar). -->
        <DockPanel Grid.Column="1" x:Name="RootScroll" Margin="10" LastChildFill="True">

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource CardBg}" CornerRadius="12"
                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" Margin="0,0,0,10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="1" Opacity="0.07" Color="#8B9CB8"/>
            </Border.Effect>
            <Grid>
                <!-- Top accent stripe -->
                <Border CornerRadius="12,12,0,0" Height="5" VerticalAlignment="Top">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#4F46E5" Offset="0"/>
                            <GradientStop Color="#06B6D4" Offset="0.5"/>
                            <GradientStop Color="#10B981" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <!-- Content -->
                <Grid Margin="24,16,24,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="{DynamicResource LogoBadgeBg}" CornerRadius="8" Padding="8,6" Margin="0,0,12,0">
                                <TextBlock Text="⚡" FontSize="18" Foreground="White"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Payrix Transaction Viewer" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="Fetch, view and export transaction data" FontSize="12" Foreground="{DynamicResource SubLabelFg}"/>
                                    <TextBlock Text="  ·  " FontSize="12" Foreground="{DynamicResource SeparatorFg}"/>
                                    <TextBlock Text="Owner: " FontSize="12" Foreground="{DynamicResource SubLabelFg}"/>
                                    <TextBlock Text="Shaheen" FontSize="12" Foreground="#4F46E5" FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Dark mode toggle — slim pill with sun/moon icons -->
                        <Border x:Name="ThemeToggleBorder" CornerRadius="14" Width="46" Height="26"
                                Margin="0,0,12,0" Cursor="Hand" MouseLeftButtonUp="ThemeToggle_Click"
                                ToolTip="Toggle Dark / Light mode"
                                Background="#E8EAF6" BorderBrush="#C5CAE9" BorderThickness="1">
                            <Grid>
                                <!-- Sun icon (left side) -->
                                <TextBlock x:Name="ThemeToggleIcon" Text="☀" FontSize="11"
                                           HorizontalAlignment="Left" VerticalAlignment="Center"
                                           Foreground="#F59E0B" Margin="5,0,0,1"/>
                                <!-- Moon icon (right side) -->
                                <TextBlock Text="🌙" FontSize="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,4,0" Opacity="0.4"/>
                                <!-- Sliding thumb -->
                                <Ellipse x:Name="ThemeToggleThumb" Width="18" Height="18"
                                         Fill="#4F46E5" HorizontalAlignment="Left"
                                         VerticalAlignment="Center" Margin="3,0,0,0"/>
                            </Grid>
                        </Border>
                        <!-- KPI toggle -->
                        <Border x:Name="KpiToggleBorder" CornerRadius="6" Cursor="Hand"
                                Padding="10,5" Margin="0,0,10,0"
                                Background="{DynamicResource SearchCardBg}" BorderBrush="{DynamicResource SearchCardBorder}" BorderThickness="1"
                                MouseLeftButtonUp="KpiToggle_Click"
                                ToolTip="Show / hide KPI summary cards">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📊" FontSize="12" Margin="0,0,5,0"/>
                                <TextBlock x:Name="KpiToggleText" Text="KPIs ▼"
                                           FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource StatusLabelFg}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Connection status pill -->
                        <Border x:Name="ConnectionPill" CornerRadius="20" Padding="10,5"
                                BorderThickness="1" BorderBrush="#BBF7D0" Background="#F0FDF4"
                                ToolTip="Green = API connected and responding  |  Red = not connected or error">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#FCA5A5"
                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock x:Name="StatusText" Text="Not connected"
                                           Foreground="{DynamicResource SubText}" FontSize="11"
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ── Controls card ──────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,8">
            <StackPanel x:Name="ControlsCardContent">
                <!-- Row 1: Environment toggle -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Environment:" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <!-- Sandbox toggle -->
                    <Border x:Name="SandboxBorder" Grid.Column="1" CornerRadius="7" Cursor="Hand"
                            Padding="16,8" MouseLeftButtonUp="SandboxBorder_Click">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource EnvBtnInactiveBg}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource EnvBtnInactiveBorder}"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSandbox, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Background" Value="#4F46E5"/>
                                        <Setter Property="BorderBrush" Value="#4338CA"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="⚡"/>
                                        <Setter Property="Foreground" Value="{DynamicResource EnvBtnInactiveFg}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSandbox, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="Sandbox" FontWeight="SemiBold" FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource EnvBtnInactiveFg}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSandbox, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <!-- Production toggle -->
                    <Border x:Name="ProductionBorder" Grid.Column="2" CornerRadius="7" Cursor="Hand"
                            Padding="16,8" Margin="8,0,0,0" MouseLeftButtonUp="ProductionBorder_Click">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource EnvBtnInactiveBg}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource EnvBtnInactiveBorder}"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSandbox, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                        <Setter Property="Background" Value="#059669"/>
                                        <Setter Property="BorderBrush" Value="#047857"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="🌐"/>
                                        <Setter Property="Foreground" Value="{DynamicResource EnvBtnInactiveFg}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSandbox, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="Production" FontWeight="SemiBold" FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource EnvBtnInactiveFg}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSandbox, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <!-- Active URL + Collapse button in the * column -->
                    <DockPanel Grid.Column="3" Margin="12,0,0,0" VerticalAlignment="Center">
                        <!-- Collapse button docked to the right -->
                        <Border DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Cursor="Hand" CornerRadius="4" Padding="7,3" Margin="8,0,0,0"
                                Background="{DynamicResource SearchCardBg}" BorderBrush="{DynamicResource SearchCardBorder}" BorderThickness="1"
                                MouseLeftButtonUp="ControlsCardToggle_Click"
                                ToolTip="Collapse / expand the search controls">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⊟  " FontSize="11" Foreground="{DynamicResource StatusLabelFg}"/>
                                <TextBlock x:Name="ControlsCardArrow" Text="Collapse" FontSize="11"
                                           FontWeight="SemiBold" Foreground="{DynamicResource StatusLabelFg}"/>
                            </StackPanel>
                        </Border>
                        <!-- Active URL fills remaining space, truncates if narrow -->
                        <TextBlock x:Name="ActiveUrlText" FontSize="11"
                                   Foreground="{DynamicResource SubText}" VerticalAlignment="Center"
                                   FontFamily="Consolas" TextTrimming="CharacterEllipsis"/>
                    </DockPanel>
                </Grid>

                <!-- Row 2: API Keys (hidden – credentials are embedded) -->
                <Grid Visibility="Collapsed">
                    <PasswordBox x:Name="SandboxApiKeyBox"/>
                    <PasswordBox x:Name="ProductionApiKeyBox"/>
                </Grid>

                <!-- Collapsible search sections wrapper -->
                <StackPanel x:Name="SearchSectionsPanel">

                <!-- ── Section: Search by Email ─────────────────────────────────────── -->
                <Border x:Name="EmailSectionHeader" Cursor="Hand" MouseLeftButtonUp="EmailSectionHeader_Click"
                        CornerRadius="6" Padding="10,7" Margin="0,6,0,0"
                        Background="{DynamicResource EmailSectionBg}" BorderBrush="{DynamicResource EmailSectionBorder}" BorderThickness="1">
                    <Grid>
                        <TextBlock Text="🔍  Search by Email" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource EmailSectionFg}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock x:Name="EmailPinBtn" Text="📍" FontSize="12" Cursor="Hand"
                                       Foreground="{DynamicResource SubLabelFg}"
                                       ToolTip="Pin to keep section expanded"
                                       Margin="0,0,10,0"
                                       MouseLeftButtonDown="EmailPinBtn_Click"/>
                            <TextBlock x:Name="EmailSectionArrow" Text="▶" FontSize="11" Foreground="{DynamicResource SubLabelFg}"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <StackPanel x:Name="EmailSectionContent" Margin="0,4,0,0" Visibility="Collapsed">
                <!-- Row 3: Single email field with Search + Fetch Latest buttons -->
                <Border Background="{DynamicResource SearchCardBg}" CornerRadius="6" Padding="12,10" Margin="0,0,0,10"
                        BorderBrush="{DynamicResource SearchCardBorder}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock Text="📧 " FontSize="13"/>
                            <TextBlock Text="User Email:" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>

                        <TextBox x:Name="UserEmailBox" Grid.Column="1" Height="34" Padding="10,0"
                                 VerticalContentAlignment="Center" FontSize="12" BorderBrush="{DynamicResource InputBorder}"
                                 BorderThickness="1"
                                 ToolTip="Used by both Search &amp; Load and Fetch Latest IDs"
                                 Text="Shaheen.Vakil@bqe.com"/>

                        <!-- Search & Load -->
                        <TextBlock Grid.Column="3" Text="Limit:" FontSize="11" Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"/>
                        <TextBox x:Name="SearchLimitBox" Grid.Column="5" Width="70" Height="34" Padding="8,0"
                                 VerticalContentAlignment="Center" FontSize="12" BorderBrush="{DynamicResource InputBorder}"
                                 BorderThickness="1" Text="20" ToolTip="Enter max number of transactions to fetch"/>
                        <Button x:Name="SearchEmailBtn" Grid.Column="7" Content="🔍 Search &amp; Load"
                                Click="SearchEmailBtn_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                    <Setter Property="Background" Value="#2563EB"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1D4ED8"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#BFDBFE"/>
                                            <Setter Property="Foreground" Value="#2563EB"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Fetch Latest IDs -->
                        <ComboBox x:Name="LatestCountBox" Grid.Column="9" Width="60" Height="34"
                                  VerticalContentAlignment="Center" FontSize="12" SelectedIndex="0">
                            <ComboBoxItem Content="1"/>
                            <ComboBoxItem Content="5"/>
                            <ComboBoxItem Content="10"/>
                            <ComboBoxItem Content="20"/>
                        </ComboBox>
                    </Grid>
                </Border>
                <Border Background="{DynamicResource QuickFetchAchBg}" CornerRadius="6" Padding="12,8" Margin="0,-6,0,10"
                        BorderBrush="{DynamicResource QuickFetchAchBorder}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="↑ Select count → fetches latest IDs (filtered by email if provided above) → pastes into Transaction IDs"
                                   FontSize="11" Foreground="{DynamicResource QuickFetchAchFg}" VerticalAlignment="Center"/>
                        <Button x:Name="FetchLatestBtn" Grid.Column="1" Content="⚡ Fetch Latest IDs"
                                Click="FetchLatestBtn_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                    <Setter Property="Background" Value="#8B5CF6"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#7C3AED"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#DDD6FE"/>
                                            <Setter Property="Foreground" Value="#7C3AED"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- Row 3b: Quick-filter fetch buttons -->
                <Border Background="{DynamicResource QuickFetchCcBg}" CornerRadius="6" Padding="12,8" Margin="0,-6,0,10"
                        BorderBrush="{DynamicResource QuickFetchCcBorder}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Quick-fetch by payment type (email filter applied if provided above, count dropdown applies):"
                                   FontSize="11" Foreground="{DynamicResource QuickFetchCcFg}" VerticalAlignment="Center"/>
                        <Button x:Name="FetchAchBtn" Grid.Column="1"
                                Content="🏦  Fetch ACH Payments"
                                Height="32" Padding="14,0" FontWeight="SemiBold" FontSize="12"
                                Cursor="Hand" BorderThickness="0"
                                Click="FetchAchBtn_Click"
                                ToolTip="Fetch all eCheck/ACH transactions (type 7 &amp; 8) for the email above">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#059669"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#047857"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#A7F3D0"/>
                                            <Setter Property="Foreground" Value="#059669"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="FetchCardBtn" Grid.Column="3"
                                Content="💳  Fetch Credit Card"
                                Height="32" Padding="14,0" FontWeight="SemiBold" FontSize="12"
                                Cursor="Hand" BorderThickness="0"
                                Click="FetchCardBtn_Click"
                                ToolTip="Fetch all credit/debit card transactions (type 1–6) for the email above">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#DB2777"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#BE185D"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#FBCFE8"/>
                                            <Setter Property="Foreground" Value="#DB2777"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                </StackPanel>

                <!-- ── Section: By Transaction ID ──────────────────────────────────── -->
                <Border x:Name="TxnSectionHeader" Cursor="Hand" MouseLeftButtonUp="TxnSectionHeader_Click"
                        CornerRadius="6" Padding="10,7" Margin="0,6,0,0"
                        Background="{DynamicResource TxnSectionBg}" BorderBrush="{DynamicResource TxnSectionBorder}" BorderThickness="1">
                    <Grid>
                        <TextBlock Text="📋  By Transaction ID" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TxnSectionFg}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock x:Name="TxnPinBtn" Text="📍" FontSize="12" Cursor="Hand"
                                       Foreground="{DynamicResource SubLabelFg}"
                                       ToolTip="Pin to keep section expanded"
                                       Margin="0,0,10,0"
                                       MouseLeftButtonDown="TxnPinBtn_Click"/>
                            <TextBlock x:Name="TxnSectionArrow" Text="▼" FontSize="11" Foreground="{DynamicResource SubLabelFg}"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <!-- Row 4: Transaction IDs + buttons -->
                <Grid x:Name="TxnSectionContent" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Transaction IDs:" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxnIdsBox" Grid.Column="1" Height="36" Padding="10,0"
                             VerticalContentAlignment="Center" FontSize="12" BorderBrush="{DynamicResource InputBorder}"
                             BorderThickness="1" ToolTip="Enter one or more transaction IDs separated by commas"
                             Text="t1_txn_6a10176e8d7bf4048722919"/>
                    <Button x:Name="FetchBtn" Grid.Column="3" Content="🔍  Fetch Transactions"
                            Click="FetchBtn_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Background" Value="#4F46E5"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#4338CA"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#C7D2FE"/>
                                        <Setter Property="Foreground" Value="#6366F1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="ClearBtn" Grid.Column="5" Content="🗑  Clear"
                            Click="ClearBtn_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource LabelFg}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Column="7" Content="🔗" Width="36" Height="36"
                            Click="ShareTxnIdBtn_Click" Cursor="Hand"
                            ToolTip="Share transaction ID(s)"
                            Background="#F5F5F7" Foreground="#007AFF" BorderBrush="#E5E5EA" BorderThickness="1">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E5E5EA"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- ── Section: By Disbursement ID ─────────────────────────────────── -->
                <Border x:Name="DisbSectionHeader" Cursor="Hand" MouseLeftButtonUp="DisbSectionHeader_Click"
                        CornerRadius="6" Padding="10,7" Margin="0,6,0,0"
                        Background="{DynamicResource DisbSectionBg}" BorderBrush="{DynamicResource DisbSectionBorder}" BorderThickness="1">
                    <Grid>
                        <TextBlock Text="💸  By Disbursement ID" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource DisbSectionFg}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock x:Name="DisbPinBtn" Text="📍" FontSize="12" Cursor="Hand"
                                       Foreground="{DynamicResource SubLabelFg}"
                                       ToolTip="Pin to keep section expanded"
                                       Margin="0,0,10,0"
                                       MouseLeftButtonDown="DisbPinBtn_Click"/>
                            <TextBlock x:Name="DisbSectionArrow" Text="▶" FontSize="11" Foreground="{DynamicResource SubLabelFg}"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <!-- Row 5: Disbursement ID search -->
                <Grid x:Name="DisbSectionContent" Margin="0,4,0,0" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Disbursement ID:" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="DisbursementIdBox" Grid.Column="1" Height="36" Padding="10,0"
                             VerticalContentAlignment="Center" FontSize="12" FontFamily="Consolas"
                             BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                             ToolTip="Enter a disbursement ID to fetch that specific disbursement, or leave blank to fetch the latest"/>
                    <TextBlock Grid.Column="3" Text="Limit:" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="DisbLimitBox" Grid.Column="5" Height="36" Padding="8,0"
                             VerticalContentAlignment="Center" FontSize="12" Text="20"
                             BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                             ToolTip="Number of disbursements to fetch when no ID is specified"/>
                    <Button x:Name="FetchDisbursementBtn" Grid.Column="7"
                            Content="💸  Fetch Disbursement"
                            Height="36" Padding="14,0" FontWeight="SemiBold" FontSize="12"
                            Cursor="Hand" BorderThickness="0"
                            Click="FetchDisbursementBtn_Click"
                            ToolTip="Fetch all transactions belonging to this disbursement ID">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#0F766E"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#0D9488"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#99F6E4"/>
                                                    <Setter Property="Foreground" Value="#0F766E"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Column="9" Content="Clear"
                            Height="36" Padding="14,0" FontSize="12"
                            Cursor="Hand" BorderThickness="0"
                            Background="#EF4444" Foreground="White"
                            Click="ClearDisbursementBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#DC2626"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="11" Content="🔗" Width="36" Height="36"
                            Click="ShareDisbIdBtn_Click" Cursor="Hand"
                            ToolTip="Share disbursement ID"
                            Background="#F5F5F7" Foreground="#007AFF" BorderBrush="#E5E5EA" BorderThickness="1">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E5E5EA"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                </StackPanel><!-- end SearchSectionsPanel -->
            </StackPanel>
        </Border>

        <!-- KPI bar (compact single row) -->
        <Border x:Name="KpiGrid" DockPanel.Dock="Top" Margin="0,0,0,8"
                Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                BorderThickness="1" CornerRadius="8" Padding="14,9">
            <UniformGrid Rows="1">

                <!-- TXN count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Total number of transactions loaded in the current result set">
                    <TextBlock Text="TXN" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryCount" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource StatCountFg}"/>
                </StackPanel>

                <!-- TOTAL $ -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Sum of the 'total' field across all transactions (in cents ÷ 100)">
                    <TextBlock Text="TOTAL" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryTotal" Text="$0.00" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource StatCountFg}"/>
                </StackPanel>

                <!-- APPROVED $ -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Sum of the 'approved' field — the amount actually authorised by the card network">
                    <TextBlock Text="APPROVED" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryApproved" Text="$0.00" FontSize="14" FontWeight="Bold"
                               Foreground="#059669"/>
                </StackPanel>

                <!-- TAX $ -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Sum of the 'tax' field across all transactions">
                    <TextBlock Text="TAX" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryTax" Text="$0.00" FontSize="14" FontWeight="Bold"
                               Foreground="#D97706"/>
                </StackPanel>

                <!-- SETTLED count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Transactions with a non-empty 'settled' timestamp (ACH type 7/8 with status=4)">
                    <TextBlock Text="SETTLED" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummarySettled" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="#7C3AED"/>
                </StackPanel>

                <!-- DECLINED count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Transactions with status=2 (Declined by the card network or processor)">
                    <TextBlock Text="DECLINED" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryDeclined" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="#EF4444"/>
                </StackPanel>

                <!-- LINE ITEMS count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Total line-item rows across all transactions (fetched separately from /transactionitems)">
                    <TextBlock Text="LINE ITEMS" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryItems" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="#4F46E5"/>
                </StackPanel>

                <!-- FEES $ -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Sum of the 'fee' field — Payrix processing fees charged on each transaction">
                    <TextBlock Text="FEES" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryFees" Text="$0.00" FontSize="14" FontWeight="Bold"
                               Foreground="#B45309"/>
                </StackPanel>

                <!-- PENDING count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Transactions with status=1 (Approved but not yet captured or settled)">
                    <TextBlock Text="PENDING" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryPending" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="#0891B2"/>
                </StackPanel>

                <!-- REFUNDED count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Transactions where the 'refunded' flag is non-zero — partial or full refund has been issued">
                    <TextBlock Text="REFUNDED" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryRefunded" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="#DB2777"/>
                </StackPanel>

                <!-- AVG $ per transaction -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Average approved amount per transaction (total approved ÷ transaction count)">
                    <TextBlock Text="AVG TXN" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryAvg" Text="$0.00" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource StatCountFg}"/>
                </StackPanel>

                <!-- DISCOUNT $ -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Sum of the 'discount' field — discounts applied at the transaction level">
                    <TextBlock Text="DISCOUNT" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryDiscount" Text="$0.00" FontSize="14" FontWeight="Bold"
                               Foreground="#65A30D"/>
                </StackPanel>

                <!-- SETTLED $ -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Sum of the 'settledTotal' field — the amount actually settled/funded to the merchant account">
                    <TextBlock Text="SETTLED $" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummarySettledAmt" Text="$0.00" FontSize="14" FontWeight="Bold"
                               Foreground="#7C3AED"/>
                </StackPanel>

                <!-- CARD count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Credit/debit card transactions (type 1=Sale, 2=Authorize, 3=Capture, 4=Refund, 5=Void, 6=Credit)">
                    <TextBlock Text="CARD" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryCard" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="#2563EB"/>
                </StackPanel>

                <!-- ACH count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="ACH / eCheck transactions (type 7=eCheck Sale, 8=eCheck Return)">
                    <TextBlock Text="ACH" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryAch" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="#0891B2"/>
                </StackPanel>

                <!-- CAPTURED count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Transactions with status=3 (Captured — authorisation has been captured for settlement)">
                    <TextBlock Text="CAPTURED" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryCaptured" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="#059669"/>
                </StackPanel>

                <!-- DISBURSED count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Transactions with type=6 (Credit/Disbursement — funds pushed out to the merchant)">
                    <TextBlock Text="DISBURSED" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryDisbursed" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="#F59E0B"/>
                </StackPanel>

                <!-- COMPANY -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Company name resolved from the BQE Core Host DB using the transaction's merchant ID">
                    <TextBlock Text="COMPANY" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryCompany" Text="—" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource StatCountFg}"
                               TextTrimming="CharacterEllipsis" MaxWidth="200"
                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                </StackPanel>

            </UniformGrid>
        </Border>

        <!-- Footer — DockPanel.Dock="Bottom" must appear BEFORE the fill child -->
        <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="📤  Export JSON" Style="{StaticResource SecondaryButton}"
                    Click="ExportJsonBtn_Click" x:Name="ExportJsonBtn" IsEnabled="False"/>
            <Button Grid.Column="2" Content="📊  Export CSV" Style="{StaticResource SecondaryButton}"
                    Click="ExportCsvBtn_Click" x:Name="ExportCsvBtn" IsEnabled="False"/>
            <TextBlock Grid.Column="3" x:Name="FooterStatus" Text="Ready"
                       Foreground="{DynamicResource SubLabelFg}"
                       FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- Tabs: fills all remaining vertical space — DataGrid scrolls within its own space -->
        <!-- Padding="0,0,16,0": right pad keeps content clear of the 14px rounded corner clipping zone -->
        <Border Style="{StaticResource Card}" Padding="0,0,16,0">
            <TabControl x:Name="MainTabControl" BorderThickness="0" Background="Transparent">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="16,10"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource TabFg}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="TabBorder" Padding="{TemplateBinding Padding}"
                                            BorderThickness="0,0,0,3" BorderBrush="Transparent"
                                            Background="{DynamicResource TabControlBg}">
                                        <ContentPresenter ContentSource="Header"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource TabSelectedBorder}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TabSelectedFg}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- Transactions Tab -->
                <!-- ═══════════════════════════════════════════════════════
                     TAB 0 — OVERVIEW DASHBOARD
                     ═══════════════════════════════════════════════════════ -->
                <TabItem Header="Overview">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20,24,24">
                        <StackPanel>
                            <!-- Page header -->
                            <StackPanel Margin="0,0,0,24">
                                <TextBlock Text="📊  Overview" FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock Text="High-level summary of the currently loaded transactions."
                                           FontSize="12.5" Foreground="{DynamicResource SubText}" Margin="0,5,0,0"/>
                            </StackPanel>

                            <!-- Row 1: 4 KPI mega-cards -->
                            <UniformGrid Columns="4" Margin="0,0,0,14">

                                <!-- Total Transactions -->
                                <Border Margin="0,0,7,0" Background="{DynamicResource CardBg}"
                                        CornerRadius="14" Padding="20,18"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                    <StackPanel>
                                        <Border Width="38" Height="38" CornerRadius="10"
                                                HorizontalAlignment="Left" Margin="0,0,0,14">
                                            <Border.Background>
                                                <SolidColorBrush Color="#1E40AF" Opacity="0.25"/>
                                            </Border.Background>
                                            <TextBlock Text="⊞" FontSize="17" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" Foreground="#60A5FA"/>
                                        </Border>
                                        <TextBlock Text="{Binding OverviewTxnCount}" FontSize="36"
                                                   FontWeight="Bold" Foreground="#60A5FA"/>
                                        <TextBlock Text="Total Transactions" FontSize="11"
                                                   Foreground="{DynamicResource SubText}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Approved Amount -->
                                <Border Margin="7,0" Background="{DynamicResource CardBg}"
                                        CornerRadius="14" Padding="20,18"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                    <StackPanel>
                                        <Border Width="38" Height="38" CornerRadius="10"
                                                HorizontalAlignment="Left" Margin="0,0,0,14">
                                            <Border.Background>
                                                <SolidColorBrush Color="#059669" Opacity="0.2"/>
                                            </Border.Background>
                                            <TextBlock Text="$" FontSize="18" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" Foreground="#34D399"/>
                                        </Border>
                                        <TextBlock Text="{Binding OverviewApproved}" FontSize="26"
                                                   FontWeight="Bold" Foreground="#34D399"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="Total Approved" FontSize="11"
                                                   Foreground="{DynamicResource SubText}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- ACH vs Card split -->
                                <Border Margin="7,0" Background="{DynamicResource CardBg}"
                                        CornerRadius="14" Padding="20,18"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="⇄  Payment Split" FontSize="10.5"
                                                   FontWeight="Bold" Foreground="{DynamicResource SubText}"
                                                   Margin="0,0,0,14"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding OverviewAchCount}" FontSize="30"
                                                           FontWeight="Bold" Foreground="#A78BFA"/>
                                                <TextBlock Text="ACH" FontSize="11"
                                                           Foreground="{DynamicResource SubText}" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding OverviewCardCount}" FontSize="30"
                                                           FontWeight="Bold" Foreground="#38BDF8"/>
                                                <TextBlock Text="Card" FontSize="11"
                                                           Foreground="{DynamicResource SubText}" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Failed / Returned -->
                                <Border Margin="7,0,0,0" Background="{DynamicResource CardBg}"
                                        CornerRadius="14" Padding="20,18"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="⚠  Issues" FontSize="10.5"
                                                   FontWeight="Bold" Foreground="{DynamicResource SubText}"
                                                   Margin="0,0,0,14"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding OverviewFailedCount}" FontSize="30"
                                                           FontWeight="Bold" Foreground="#F87171"/>
                                                <TextBlock Text="Failed" FontSize="11"
                                                           Foreground="{DynamicResource SubText}" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding OverviewReturnedCount}" FontSize="30"
                                                           FontWeight="Bold" Foreground="#FBBF24"/>
                                                <TextBlock Text="Returned" FontSize="11"
                                                           Foreground="{DynamicResource SubText}" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                            </UniformGrid>

                            <!-- Row 2: secondary stats -->
                            <UniformGrid Columns="3" Margin="0,0,0,20">

                                <!-- Settled Count + Amount -->
                                <Border Margin="0,0,7,0" Background="{DynamicResource CardBg}"
                                        CornerRadius="14" Padding="20,16"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="SETTLED COUNT" FontSize="9" FontWeight="Bold"
                                                       Foreground="{DynamicResource MutedText}" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding OverviewSettledCount}" FontSize="26"
                                                       FontWeight="Bold" Foreground="#4ADE80"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="SETTLED AMOUNT" FontSize="9" FontWeight="Bold"
                                                       Foreground="{DynamicResource MutedText}" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding OverviewSettledAmount}" FontSize="20"
                                                       FontWeight="Bold" Foreground="#4ADE80"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Pending -->
                                <Border Margin="7,0" Background="{DynamicResource CardBg}"
                                        CornerRadius="14" Padding="20,16"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="PENDING" FontSize="9" FontWeight="Bold"
                                                       Foreground="{DynamicResource MutedText}" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding OverviewPendingCount}" FontSize="26"
                                                       FontWeight="Bold" Foreground="#FBBF24"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="CAPTURED" FontSize="9" FontWeight="Bold"
                                                       Foreground="{DynamicResource MutedText}" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding OverviewCapturedCount}" FontSize="26"
                                                       FontWeight="Bold" Foreground="#818CF8"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Avg transaction + Disbursed -->
                                <Border Margin="7,0,0,0" Background="{DynamicResource CardBg}"
                                        CornerRadius="14" Padding="20,16"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="AVG AMOUNT" FontSize="9" FontWeight="Bold"
                                                       Foreground="{DynamicResource MutedText}" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding OverviewAvgAmount}" FontSize="22"
                                                       FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="DISBURSED" FontSize="9" FontWeight="Bold"
                                                       Foreground="{DynamicResource MutedText}" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding OverviewDisbursedCount}" FontSize="26"
                                                       FontWeight="Bold" Foreground="#FB923C"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                            </UniformGrid>

                            <!-- ── API Tools section ─────────────────────── -->
                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Text="🔌  API Tools" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,10"/>

                                <!-- Row 3: 3 API stat cards -->
                                <UniformGrid Columns="3" Margin="0,0,0,10">

                                    <!-- Total Endpoints -->
                                    <Border Margin="0,0,7,0" Background="{DynamicResource CardBg}"
                                            CornerRadius="14" Padding="20,18"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <Border Width="38" Height="38" CornerRadius="10"
                                                    HorizontalAlignment="Left" Margin="0,0,0,14">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#7C3AED" Opacity="0.22"/>
                                                </Border.Background>
                                                <TextBlock Text="⚡" FontSize="17" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="#A78BFA"/>
                                            </Border>
                                            <TextBlock Text="{Binding OverviewApiCountFmt}" FontSize="36"
                                                       FontWeight="Bold" Foreground="#A78BFA"/>
                                            <TextBlock Text="Total API Endpoints" FontSize="11"
                                                       Foreground="{DynamicResource SubText}" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Collections -->
                                    <Border Margin="7,0" Background="{DynamicResource CardBg}"
                                            CornerRadius="14" Padding="20,18"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <Border Width="38" Height="38" CornerRadius="10"
                                                    HorizontalAlignment="Left" Margin="0,0,0,14">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#0EA5E9" Opacity="0.2"/>
                                                </Border.Background>
                                                <TextBlock Text="📁" FontSize="16" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="#38BDF8"/>
                                            </Border>
                                            <TextBlock Text="{Binding OverviewCollectionCount}" FontSize="36"
                                                       FontWeight="Bold" Foreground="#38BDF8"/>
                                            <TextBlock Text="Collections" FontSize="11"
                                                       Foreground="{DynamicResource SubText}" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Recent Requests -->
                                    <Border Margin="7,0,0,0" Background="{DynamicResource CardBg}"
                                            CornerRadius="14" Padding="20,18"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <Border Width="38" Height="38" CornerRadius="10"
                                                    HorizontalAlignment="Left" Margin="0,0,0,14">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#F59E0B" Opacity="0.18"/>
                                                </Border.Background>
                                                <TextBlock Text="🕐" FontSize="15" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="#FCD34D"/>
                                            </Border>
                                            <TextBlock Text="{Binding OverviewRecentCount}" FontSize="36"
                                                       FontWeight="Bold" Foreground="#FCD34D"/>
                                            <TextBlock Text="Recent Requests" FontSize="11"
                                                       Foreground="{DynamicResource SubText}" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>

                                </UniformGrid>

                                <!-- Per-collection breakdown mini-table -->
                                <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="16,14"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="ENDPOINTS BY COLLECTION" FontSize="9" FontWeight="Bold"
                                                   Foreground="{DynamicResource MutedText}" Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding OverviewTopCollections}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,7">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <!-- Name -->
                                                        <TextBlock Text="{Binding Item1}" FontSize="12"
                                                                   Foreground="{DynamicResource PrimaryText}"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <!-- Count pill -->
                                                        <Border Grid.Column="1" CornerRadius="5"
                                                                Background="{DynamicResource TabHoverBg}"
                                                                Padding="8,2" Margin="10,0,0,0">
                                                            <TextBlock Text="{Binding Item2}" FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#A78BFA"/>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Empty-state hint -->
                            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20,16"
                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="💡" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock FontSize="12.5" Foreground="{DynamicResource SubText}"
                                               VerticalAlignment="Center">
                                        Use the <Run FontWeight="SemiBold" Foreground="#818CF8">Transactions</Run>
                                        tab to load data — stats update automatically.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══════════════════════════════════════════════════════
                     TAB 1 — TRANSACTIONS (original tab 0)
                     ═══════════════════════════════════════════════════════ -->
                <TabItem Header="Transactions">
                    <DataGrid x:Name="TxnGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserResizeColumns="True" GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="{DynamicResource GridAltRowBg}"
                              RowBackground="{DynamicResource GridRowBg}"
                              Foreground="{DynamicResource GridFg}"
                              HeadersVisibility="Column" BorderThickness="0"
                              SelectionUnit="Cell" SelectionMode="Single"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              FontSize="12" RowHeight="NaN"
                              SelectionChanged="TxnGrid_SelectionChanged"
                              MouseDoubleClick="TxnGrid_MouseDoubleClick"
                              ContextMenu="{StaticResource GridContextMenu}"
                              ContextMenuOpening="Grid_ContextMenuOpening">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource GridHeaderBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource GridHeaderFg}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource GridBorder}"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <!-- Row style: hand cursor + tooltip -->
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="ToolTip" Value="Double-click to open in ePayments portal"/>
                                <Setter Property="Background" Value="{DynamicResource GridRowBg}"/>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <!-- Portal link column -->
                            <DataGridTemplateColumn Header="🔗" Width="36" CanUserResize="False" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🔗"
                                                FontSize="13" Cursor="Hand"
                                                Background="Transparent" BorderThickness="0"
                                                Padding="2,0" HorizontalAlignment="Center"
                                                ToolTip="Open in ePayments portal"
                                                Click="PortalLinkBtn_Click"
                                                Tag="{Binding Id}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="220"/>
                            <DataGridTextColumn Header="Created" Binding="{Binding Created}" Width="160"/>
                            <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="150"/>
                            <DataGridTextColumn Header="Merchant" Binding="{Binding MerchantDisplayName}" Width="160"/>
                            <DataGridTextColumn Header="Disbursement ID" Binding="{Binding DisbursementId}" Width="220"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                            <DataGridTextColumn Header="Order" Binding="{Binding Order}" Width="160"/>
                            <DataGridTextColumn Header="Currency" Binding="{Binding Currency}" Width="80"/>
                            <DataGridTextColumn Header="Total"    Binding="{Binding TotalFormatted}"    Width="100"/>
                            <DataGridTextColumn Header="Approved" Binding="{Binding ApprovedFormatted}" Width="100"/>
                            <DataGridTextColumn Header="Tax"      Binding="{Binding TaxFormatted}"      Width="80"/>
                            <DataGridTextColumn Header="Authorization" Binding="{Binding Authorization}" Width="110"/>
                            <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="90"/>
                            <DataGridTextColumn Header="Merchant" Binding="{Binding Merchant}" Width="220"/>
                            <DataGridTextColumn Header="Batch" Binding="{Binding Batch}" Width="220"/>
                            <DataGridTextColumn Header="City" Binding="{Binding City}" Width="120"/>
                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="140"/>
                            <DataGridTextColumn Header="Country" Binding="{Binding Country}" Width="80"/>
                            <DataGridTemplateColumn Header="Discrepancy" Width="280">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="6,4" Margin="2"
                                                HorizontalAlignment="Stretch">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDiscrepancy}" Value="True">
                                                            <Setter Property="Background" Value="#FEE2E2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <!-- Status badge row -->
                                                <TextBlock Text="{Binding DiscrepancyLabel}"
                                                           FontWeight="Bold" FontSize="11" Margin="0,0,0,2">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#166534"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasDiscrepancy}" Value="True">
                                                                    <Setter Property="Foreground" Value="#991B1B"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <!-- Transaction ID — only shown when there is a mismatch -->
                                                <TextBlock FontSize="10" Foreground="#7F1D1D" FontStyle="Italic"
                                                           Margin="0,0,0,2" TextWrapping="Wrap" MaxWidth="260">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasDiscrepancy}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text="Txn: "/><Run Text="{Binding Id}" FontWeight="SemiBold"/>
                                                </TextBlock>
                                                <!-- Reason lines — only visible when there are issues -->
                                                <TextBlock Text="{Binding DiscrepancySummary}"
                                                           FontSize="10.5" TextWrapping="Wrap"
                                                           Foreground="#7F1D1D" MaxWidth="260">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasDiscrepancy}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Gateway" Binding="{Binding Gateway}" Width="110"/>
                            <DataGridTextColumn Header="Payment Type" Binding="{Binding PaymentTypeLabel}" Width="110"/>
                            <DataGridTextColumn Header="Payment Method" Binding="{Binding PaymentMethodDisplay}" Width="160"/>
                            <DataGridTemplateColumn Header="Status" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="1">
                                                            <Setter Property="Background" Value="#DCFCE7"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="2">
                                                            <Setter Property="Background" Value="#FEE2E2"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="3">
                                                            <Setter Property="Background" Value="{DynamicResource InfoStripBlueBtnHover}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="4">
                                                            <Setter Property="Background" Value="#FEE2E2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding StatusLabel}" FontWeight="SemiBold" FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#475569"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="1">
                                                                <Setter Property="Foreground" Value="#166534"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="2">
                                                                <Setter Property="Foreground" Value="#991B1B"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="3">
                                                                <Setter Property="Foreground" Value="#1E40AF"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="4">
                                                                <Setter Property="Foreground" Value="#991B1B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Type" Binding="{Binding TypeLabel}" Width="100"/>
                            <!-- Webhook button — active for ALL transaction types -->
                            <DataGridTemplateColumn Header="Webhook" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="⚡ Webhook"
                                                Tag="{Binding}"
                                                Click="BuildAchWebhookBtn_Click"
                                                Padding="6,3" FontSize="11" FontWeight="SemiBold"
                                                Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#7C3AED"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        CornerRadius="5"
                                                                        Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#6D28D9"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <!-- Line Items Tab -->
                <TabItem Header="Line Items">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                    <!-- Placeholder shown when no transaction is selected -->
                    <Border x:Name="ItemsPlaceholder" Grid.Row="0" Background="{DynamicResource CardBg}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📋" FontSize="40" HorizontalAlignment="Center"
                                       Margin="0,0,0,12" Opacity="0.3"/>
                            <TextBlock Text="Select a transaction to view its line items"
                                       FontSize="14" Foreground="{DynamicResource HintFg}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Click any row in the Transactions tab"
                                       FontSize="12" Foreground="{DynamicResource SeparatorFg}" HorizontalAlignment="Center"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Disbursement entries grid (shown when a disbursement is fetched) -->
                    <DataGrid x:Name="DisbEntryGrid" Grid.Row="0" Visibility="Collapsed"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserResizeColumns="True" GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="{DynamicResource GridAltRowBg}" RowBackground="{DynamicResource GridRowBg}"
                              HeadersVisibility="Column" BorderThickness="0"
                              SelectionUnit="Cell" SelectionMode="Single"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              ContextMenu="{StaticResource GridContextMenu}"
                              ContextMenuOpening="Grid_ContextMenuOpening"
                              FontSize="12">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource GridHeaderBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource GridHeaderFg}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource GridBorder}"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Entry ID"      Binding="{Binding Id}"             Width="220"/>
                            <DataGridTextColumn Header="Transaction ID" Binding="{Binding EventId}"       Width="220"/>
                            <DataGridTextColumn Header="Disbursement"  Binding="{Binding Disbursement}"   Width="220"/>
                            <DataGridTextColumn Header="Created"       Binding="{Binding Created}"        Width="160"/>
                            <DataGridTextColumn Header="Description"   Binding="{Binding Description}"    Width="200"/>
                            <DataGridTextColumn Header="Amount"        Binding="{Binding AmountFormatted}" Width="110"/>
                            <DataGridTextColumn Header="Event Type"    Binding="{Binding Event}"          Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <DataGrid x:Name="ItemsGrid" Grid.Row="0" Visibility="Collapsed"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserResizeColumns="True" GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="{DynamicResource GridAltRowBg}" RowBackground="{DynamicResource GridRowBg}"
                              HeadersVisibility="Column" BorderThickness="0"
                              SelectionUnit="Cell" SelectionMode="Single"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              ContextMenu="{StaticResource GridContextMenu}"
                              ContextMenuOpening="Grid_ContextMenuOpening"
                              FontSize="12">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource GridHeaderBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource GridHeaderFg}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource GridBorder}"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item ID" Binding="{Binding Id}" Width="220"/>
                            <DataGridTextColumn Header="Transaction ID" Binding="{Binding Txn}" Width="220"/>
                            <DataGridTextColumn Header="Created" Binding="{Binding Created}" Width="160"/>
                            <DataGridTextColumn Header="Item" Binding="{Binding Item}" Width="160"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="180"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="60"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding PriceFormatted}" Width="90"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalFormatted}" Width="90"/>
                            <DataGridTextColumn Header="Discount" Binding="{Binding Discount}" Width="80"/>
                            <DataGridTextColumn Header="UM" Binding="{Binding Um}" Width="70"/>
                            <DataGridTextColumn Header="Commodity Code" Binding="{Binding CommodityCode}" Width="130"/>
                            <DataGridTextColumn Header="Product Code" Binding="{Binding ProductCode}" Width="150"/>
                            <DataGridTextColumn Header="Discount Treatment" Binding="{Binding DiscountTreatment}" Width="140"/>
                            <DataGridTextColumn Header="Line Item Indicator" Binding="{Binding LineItemDetailIndicatorLabel}" Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Grand total footer row -->
                    <Border x:Name="ItemsGrandTotalRow" Grid.Row="1"
                            Background="{DynamicResource KpiHeaderBg}" BorderThickness="0">
                        <Grid>
                            <!-- Columns mirror the DataGrid columns widths exactly -->
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>  <!-- Item ID -->
                                <ColumnDefinition Width="220"/>  <!-- Transaction ID -->
                                <ColumnDefinition Width="160"/>  <!-- Created -->
                                <ColumnDefinition Width="160"/>  <!-- Item -->
                                <ColumnDefinition Width="180"/>  <!-- Description -->
                                <ColumnDefinition Width="60"/>   <!-- Qty -->
                                <ColumnDefinition Width="90"/>   <!-- Price -->
                                <ColumnDefinition Width="90"/>   <!-- Total -->
                                <ColumnDefinition Width="*"/>    <!-- rest -->
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="4" Grid.ColumnSpan="2" Text="Grand Total"
                                       FontWeight="Bold" FontSize="12" Foreground="White"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Padding="0,6,8,6"/>

                            <TextBlock x:Name="GrandTotalPrice" Grid.Column="6"
                                       FontWeight="Bold" FontSize="12" Foreground="{DynamicResource KpiHeaderFg}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Padding="0,6,10,6"/>

                            <TextBlock x:Name="GrandTotalAmount" Grid.Column="7"
                                       FontWeight="Bold" FontSize="13" Foreground="White"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Padding="0,6,10,6"/>
                        </Grid>
                    </Border>

                    <!-- Line Items summary bar -->
                    <Border x:Name="ItemsSummaryBar" Grid.Row="2"
                            Margin="0,0,0,0" Padding="14,10" BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource CardBorder2}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#F0FDF4"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=ItemsMismatchIcon, Path=Visibility}"
                                                 Value="Visible">
                                        <Setter Property="Background" Value="#FFF1F2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Line Items Sum:" FontWeight="SemiBold" FontSize="12"
                                           Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ItemsSumText" Text="$0.00" FontWeight="Bold"
                                           FontSize="13" Foreground="{DynamicResource KpiValueFg}"
                                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="vs" FontSize="12" Foreground="{DynamicResource HintFg}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <TextBlock Text="Transaction Approved:" FontWeight="SemiBold" FontSize="12"
                                           Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ItemsTxnTotalText" Text="$0.00" FontWeight="Bold"
                                           FontSize="13" Foreground="{DynamicResource KpiValueFg}"
                                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Grid.Column="3" Text="→" FontSize="12" Foreground="{DynamicResource HintFg}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <!-- Match indicator -->
                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="ItemsMatchIcon" Text="✓ Match"
                                           FontWeight="Bold" FontSize="12" Foreground="#166534"/>
                                <StackPanel x:Name="ItemsMismatchIcon" Orientation="Horizontal"
                                            Visibility="Collapsed">
                                    <TextBlock Text="⚠ Mismatch — difference: " FontWeight="Bold"
                                               FontSize="12" Foreground="#991B1B"/>
                                    <TextBlock x:Name="ItemsDiffText" FontWeight="Bold"
                                               FontSize="12" Foreground="#991B1B"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock x:Name="ItemsCountText" Grid.Column="6"
                                       FontSize="11" Foreground="{DynamicResource HintFg}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    </Grid>
                </TabItem>

                <!-- Post Txn (Level 2/3) Tab -->
                <TabItem Header="Post Txn">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16,20,20">
                        <StackPanel>

                            <!-- Header card -->
                            <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                                    BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="📋  Post Transaction with Line Item Detail"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="{DynamicResource TitleFg}"/>
                                        <Border Background="#1D4ED8" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="lineItemDetailIndicator = 1"
                                                       Foreground="White" FontSize="10" FontWeight="Bold"
                                                       FontFamily="Consolas"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Submit a Payrix POST /txns with Level 2/Level 3 enhanced line item data. All amounts are in cents (e.g. 1099 = $10.99)."
                                               FontSize="12" Foreground="{DynamicResource HintFg}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Transaction fields card -->
                            <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                                    BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="80"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto" MinWidth="80"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto" MinWidth="80"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto" MinWidth="80"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Row 0: Merchant, Token, Type, Amount -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Merchant ID:"
                                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                               Foreground="{DynamicResource LabelFg}"/>
                                    <TextBox x:Name="PostTxnMerchantBox" Grid.Row="0" Grid.Column="2"
                                             Height="32" Padding="8,0" FontFamily="Consolas" FontSize="11"
                                             VerticalContentAlignment="Center"
                                             BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                             ToolTip="Payrix merchant ID"/>

                                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Token:"
                                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                               Foreground="{DynamicResource LabelFg}"
                                               ToolTip="Payrix vault token — the ID of a stored card or ACH payment method&#x0a;(from GET /tokens for this merchant). Click 🔍 to fetch tokens."/>
                                    <!-- Token ComboBox + fetch + create + txn shortcut -->
                                    <Grid Grid.Row="0" Grid.Column="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="PostTxnTokenBox" Grid.Column="0"
                                                  IsEditable="True" Height="32" Padding="6,0"
                                                  FontFamily="Consolas" FontSize="11"
                                                  VerticalContentAlignment="Center"
                                                  SelectionChanged="PostTxnTokenBox_SelectionChanged"
                                                  BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                  ToolTip="Payrix vault token — the ID of a stored card/ACH payment method.&#x0a;Click 🔍 to fetch all tokens for the entered Merchant ID."/>
                                        <Button x:Name="PostTxnFetchTokensBtn" Grid.Column="2"
                                                Content="🔍" Height="32" Width="32" FontSize="13"
                                                Cursor="Hand" BorderThickness="1"
                                                BorderBrush="{DynamicResource InputBorder}"
                                                Background="{DynamicResource CardBg}"
                                                Foreground="{DynamicResource PrimaryText}"
                                                Click="PostTxnFetchTokensBtn_Click"
                                                ToolTip="Fetch all vault tokens for the Merchant ID above and populate the dropdown"/>
                                        <Button x:Name="PostTxnUseSelectedTxnBtn" Grid.Column="4"
                                                Content="← txn" Height="32" Padding="8,0" FontSize="11"
                                                Cursor="Hand" BorderThickness="1"
                                                BorderBrush="{DynamicResource InputBorder}"
                                                Background="{DynamicResource CardBg}"
                                                Foreground="{DynamicResource PrimaryText}"
                                                Click="PostTxnUseSelectedTxnBtn_Click"
                                                ToolTip="Copy Token + Merchant from the selected row in the Transactions grid&#x0a;This is the most reliable source — the token was used in a real transaction"/>
                                        <Button x:Name="PostTxnCreateTokenBtn" Grid.Column="6"
                                                Content="+ Token" Height="32" Padding="8,0" FontSize="11"
                                                Cursor="Hand" BorderThickness="1"
                                                BorderBrush="#34C759" Background="#F0FDF4" Foreground="#166534"
                                                Click="PostTxnCreateTokenBtn_Click"
                                                ToolTip="Create a new vault token using the sandbox test card&#x0a;Visa 4111111111111111 exp 12/25 CVV 999&#x0a;Requires Merchant ID to be filled in"/>
                                    </Grid>

                                    <TextBlock Grid.Row="0" Grid.Column="8" Text="Type:"
                                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                               Foreground="{DynamicResource LabelFg}"/>
                                    <ComboBox x:Name="PostTxnTypeBox" Grid.Row="0" Grid.Column="10"
                                              Height="32" FontSize="12" VerticalContentAlignment="Center"
                                              SelectedIndex="0">
                                        <ComboBoxItem Content="1 — Sale"/>
                                        <ComboBoxItem Content="2 — Authorize"/>
                                        <ComboBoxItem Content="3 — Capture"/>
                                    </ComboBox>

                                    <TextBlock Grid.Row="0" Grid.Column="12" Text="Total (¢):"
                                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                               Foreground="{DynamicResource LabelFg}"/>
                                    <TextBox x:Name="PostTxnTotalBox" Grid.Row="0" Grid.Column="14"
                                             Height="32" Padding="8,0" FontFamily="Consolas" FontSize="11"
                                             VerticalContentAlignment="Center" Text="1099"
                                             BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                             ToolTip="Transaction total in cents (e.g. 1099 = $10.99)"/>

                                    <!-- Row 2: Tax, Description, Order -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Tax (¢):"
                                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                               Foreground="{DynamicResource LabelFg}"/>
                                    <TextBox x:Name="PostTxnTaxBox" Grid.Row="2" Grid.Column="2"
                                             Height="32" Padding="8,0" FontFamily="Consolas" FontSize="11"
                                             VerticalContentAlignment="Center" Text="0"
                                             BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                             ToolTip="Tax amount in cents"/>

                                    <TextBlock Grid.Row="2" Grid.Column="4" Text="Description:"
                                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                               Foreground="{DynamicResource LabelFg}"/>
                                    <TextBox x:Name="PostTxnDescBox" Grid.Row="2" Grid.Column="6"
                                             Height="32" Padding="8,0" FontSize="12"
                                             VerticalContentAlignment="Center"
                                             BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                             ToolTip="Optional transaction description"/>

                                    <TextBlock Grid.Row="2" Grid.Column="8" Text="Order/Invoice:"
                                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                               Foreground="{DynamicResource LabelFg}"/>
                                    <TextBox x:Name="PostTxnOrderBox" Grid.Row="2" Grid.Column="10"
                                             Height="32" Padding="8,0" FontFamily="Consolas" FontSize="11"
                                             VerticalContentAlignment="Center"
                                             BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                             ToolTip="Optional order/invoice reference"/>

                                    <TextBlock Grid.Row="2" Grid.Column="12" Text="Origin:"
                                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                               Foreground="{DynamicResource LabelFg}"
                                               ToolTip="Transaction origin — required by Payrix&#x0a;1=API  2=Virtual Terminal  3=Mobile  4=POS"/>
                                    <ComboBox x:Name="PostTxnOriginBox" Grid.Row="2" Grid.Column="14"
                                              Height="32" FontSize="12" VerticalContentAlignment="Center"
                                              SelectedIndex="0"
                                              ToolTip="1 = API (default for programmatic calls)&#x0a;2 = Virtual Terminal&#x0a;3 = Mobile&#x0a;4 = POS">
                                        <ComboBoxItem Content="1 — API"               Tag="1"/>
                                        <ComboBoxItem Content="2 — Virtual Terminal"  Tag="2"/>
                                        <ComboBoxItem Content="3 — Mobile"            Tag="3"/>
                                        <ComboBoxItem Content="4 — POS"               Tag="4"/>
                                    </ComboBox>

                                    <!-- Row 4: lineItemDetailIndicator info banner -->
                                    <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="15"
                                            Background="{DynamicResource InfoBannerBg}"
                                            BorderBrush="{DynamicResource InfoBannerBorder}"
                                            BorderThickness="1" CornerRadius="6" Padding="10,7"
                                            Margin="0,4,0,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="lineItemDetailIndicator" FontFamily="Consolas"
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="{DynamicResource InfoBannerTitleFg}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="  — set per line item in the grid below"
                                                           FontSize="11" Foreground="{DynamicResource InfoBannerTextFg}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock FontSize="11" Foreground="{DynamicResource InfoBannerTextFg}"
                                                       TextWrapping="Wrap">
                                                <Run Text="0" Foreground="{DynamicResource InfoBannerNumFg}"/>
                                                <Run Text=" Normal  " Foreground="{DynamicResource InfoBannerTextFg}"/>
                                                <Run Text="1" Foreground="{DynamicResource InfoBannerNumFg}"/>
                                                <Run Text=" Normal (last)  " Foreground="{DynamicResource InfoBannerTextFg}"/>
                                                <Run Text="2" Foreground="{DynamicResource InfoBannerNumFg}"/>
                                                <Run Text=" Credit  " Foreground="{DynamicResource InfoBannerTextFg}"/>
                                                <Run Text="3" Foreground="{DynamicResource InfoBannerNumFg}"/>
                                                <Run Text=" Credit (last)  " Foreground="{DynamicResource InfoBannerTextFg}"/>
                                                <Run Text="4" Foreground="{DynamicResource InfoBannerNumFg}"/>
                                                <Run Text=" Payment  " Foreground="{DynamicResource InfoBannerTextFg}"/>
                                                <Run Text="5" Foreground="{DynamicResource InfoBannerNumFg}"/>
                                                <Run Text=" Payment (last) — leave blank to auto-assign (last item → 1, others → 0)" Foreground="{DynamicResource InfoBannerTextFg}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Line items card -->
                            <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                                    BorderThickness="1" CornerRadius="8" Padding="0,0,0,0" Margin="0,0,0,12"
                                    ClipToBounds="True">
                                <StackPanel>
                                    <!-- Sub-header -->
                                    <Border Background="{DynamicResource KpiHeaderBg}" Padding="14,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Line Items  (prices in cents)"
                                                       FontSize="12" FontWeight="Bold"
                                                       Foreground="White" VerticalAlignment="Center"/>
                                            <Button x:Name="PostTxnAddItemBtn" Grid.Column="1"
                                                    Content="＋  Add Item" Height="28" Padding="10,0"
                                                    FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                                    BorderThickness="0" Background="#16A34A" Foreground="White"
                                                    Click="PostTxnAddItemBtn_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#15803D"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button x:Name="PostTxnRemoveItemBtn" Grid.Column="3"
                                                    Content="✕  Remove" Height="28" Padding="10,0"
                                                    FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                                    BorderThickness="0" Background="#DC2626" Foreground="White"
                                                    Click="PostTxnRemoveItemBtn_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#B91C1C"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <!-- Editable line items DataGrid -->
                                    <DataGrid x:Name="PostTxnItemsGrid"
                                              AutoGenerateColumns="False" IsReadOnly="False"
                                              CanUserAddRows="False" CanUserDeleteRows="False"
                                              CanUserResizeColumns="True" GridLinesVisibility="Horizontal"
                                              AlternatingRowBackground="{DynamicResource GridAltRowBg}"
                                              RowBackground="{DynamicResource GridRowBg}"
                                              HeadersVisibility="Column" BorderThickness="0"
                                              SelectionUnit="Cell" SelectionMode="Single"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto"
                                              MaxHeight="260"
                                              FontSize="12">
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="{DynamicResource GridHeaderBg}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource GridHeaderFg}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Padding" Value="8,6"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource GridBorder}"/>
                                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="#"                  Binding="{Binding ItemSequenceNumber}"       Width="38"  IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Description"         Binding="{Binding Description}"              Width="160"/>
                                            <DataGridTextColumn Header="Qty"                Binding="{Binding Quantity}"                 Width="50"/>
                                            <DataGridTextColumn Header="Price (¢)"          Binding="{Binding Price}"                    Width="80"/>
                                            <DataGridTextColumn Header="Total (¢)"          Binding="{Binding Total}"                    Width="80"/>
                                            <DataGridTextColumn Header="Tax (¢)"            Binding="{Binding TaxAmount}"                Width="70"/>
                                            <DataGridTextColumn Header="Tax Rate %"         Binding="{Binding TaxRate}"                  Width="80"/>
                                            <DataGridTextColumn Header="Tax In Total"       Binding="{Binding TaxIncludedInTotal}"        Width="90"/>
                                            <DataGridTextColumn Header="UM"                 Binding="{Binding Um}"                       Width="50"/>
                                            <DataGridTextColumn Header="Product Code"       Binding="{Binding ProductCode}"              Width="110"/>
                                            <DataGridTextColumn Header="Commodity"          Binding="{Binding CommodityCode}"            Width="100"/>
                                            <DataGridTextColumn Header="Discount (¢)"       Binding="{Binding Discount}"                 Width="90"/>
                                            <DataGridTemplateColumn Header="lineItemDetailIndicator (0–5)" Width="190">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding LineItemDetailIndicatorLabel}" Padding="4,2"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <!-- SelectedItem bound to string property — avoids int?/string type mismatch -->
                                                        <ComboBox SelectedItem="{Binding LineItemDetailIndicatorStr, UpdateSourceTrigger=PropertyChanged}">
                                                            <sys:String>0</sys:String>
                                                            <sys:String>1</sys:String>
                                                            <sys:String>2</sys:String>
                                                            <sys:String>3</sys:String>
                                                            <sys:String>4</sys:String>
                                                            <sys:String>5</sys:String>
                                                        </ComboBox>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellEditingTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <!-- POST button row -->
                            <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                                    BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button x:Name="PostTxnBtn" Grid.Column="0"
                                            Content="⚡  POST /txns" Height="36" Padding="18,0"
                                            FontWeight="Bold" FontSize="13" Cursor="Hand"
                                            BorderThickness="0" Background="#1D4ED8" Foreground="White"
                                            Click="PostTxnBtn_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1E40AF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Background" Value="#93C5FD"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <TextBlock x:Name="PostTxnStatus" Grid.Column="2"
                                               FontSize="12" VerticalAlignment="Center"
                                               Foreground="{DynamicResource LabelFg}"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </Border>

                            <!-- Response card (shown after POST) -->
                            <Border x:Name="PostTxnResponseCard"
                                    Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                                    BorderThickness="1" CornerRadius="8" Padding="14,10"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="API Response" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource LabelFg}" Margin="0,0,0,6"/>
                                    <Border Background="{DynamicResource CodeBg}" CornerRadius="4">
                                        <TextBox x:Name="PostTxnResponseBox"
                                                 IsReadOnly="True" TextWrapping="Wrap"
                                                 FontFamily="Consolas" FontSize="11"
                                                 Foreground="{DynamicResource CodeFg}"
                                                 SelectionBrush="{DynamicResource CodeFg}" SelectionOpacity="0.3"
                                                 BorderThickness="0" Padding="8,6"
                                                 MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                            <!-- Strip the default TextBox template so it doesn't paint a white SystemColors.WindowBrush
                                                 over the parent Border's CodeBg background. -->
                                            <TextBox.Template>
                                                <ControlTemplate TargetType="TextBox">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Background="Transparent"
                                                                  Padding="{TemplateBinding Padding}"
                                                                  VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"/>
                                                </ControlTemplate>
                                            </TextBox.Template>
                                        </TextBox>
                                    </Border>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Webhook Tests Tab -->
                <TabItem Header="Webhook Tests">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><!-- Row 0: POST panel -->
                            <RowDefinition Height="Auto"/><!-- Row 1: Transaction detail card -->
                            <RowDefinition Height="Auto"/><!-- Row 2: Controls -->
                            <RowDefinition Height="*"/>  <!-- Row 3: Results+Summary+Payload wrapper -->
                        </Grid.RowDefinitions>

                        <!-- ── Unified Webhook POST panel ────────────────────── -->
                        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled" Margin="0,0,0,8">
                        <Border x:Name="WebhookPostBorder"
                                Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                                BorderThickness="1" CornerRadius="8" Padding="10,6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto" MinWidth="160"/>
                                </Grid.ColumnDefinitions>

                                <!-- Badge — updated by WebhookTypeBox_SelectionChanged -->
                                <Border x:Name="WebhookTypeBadge" Grid.Column="0" Background="#16A34A"
                                        CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                                    <TextBlock x:Name="WebhookTypeBadgeText" Text="ACH FUNDED"
                                               Foreground="White" FontWeight="Bold" FontSize="11"/>
                                </Border>

                                <!-- Type dropdown -->
                                <TextBlock Grid.Column="2" Text="Type:" FontSize="12"
                                           FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{DynamicResource LabelFg}"/>
                                <ComboBox x:Name="WebhookTypeBox" Grid.Column="4"
                                          Height="32" FontSize="12" VerticalContentAlignment="Center"
                                          SelectionChanged="WebhookTypeBox_SelectionChanged"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="ACH Funded"/>
                                    <ComboBoxItem Content="ACH Return"/>
                                    <ComboBoxItem Content="CC Refund"/>
                                    <ComboBoxItem Content="CC Return"/>
                                    <ComboBoxItem Content="Disbursement"/>
                                    <ComboBoxItem Content="Withdrawal"/>
                                    <ComboBoxItem Content="ACH Refund"/>
                                    <ComboBoxItem Content="Withdrawal Processed"/>
                                    <ComboBoxItem Content="Entities Created"/>
                                    <ComboBoxItem Content="Merchant Boarded"/>
                                </ComboBox>

                                <!-- txnId -->
                                <TextBlock Grid.Column="6" Text="txnId:" FontSize="12"
                                           FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{DynamicResource LabelFg}"/>
                                <TextBox x:Name="AchTxnIdBox" Grid.Column="8"
                                         Height="32" Padding="8,0" FontFamily="Consolas"
                                         FontSize="11" VerticalContentAlignment="Center"
                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1" Text=""
                                         ToolTip="Transaction ID. Leave blank to auto-fetch the most recent matching transaction, or enter a specific ID."/>

                                <!-- Amount -->
                                <TextBlock Grid.Column="10" Text="Amount:" FontSize="12"
                                           FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{DynamicResource LabelFg}"/>
                                <TextBox x:Name="AchAmountBox" Grid.Column="12"
                                         Height="32" Padding="8,0" FontFamily="Consolas"
                                         FontSize="11" VerticalContentAlignment="Center"
                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1" Text="898.00"/>

                                <!-- POST button -->
                                <Button x:Name="AchPostBtn" Grid.Column="14"
                                        Content="⚡  Send POST" Height="32" Padding="14,0"
                                        FontWeight="Bold" FontSize="12" Cursor="Hand"
                                        BorderThickness="0" Background="#16A34A" Foreground="White"
                                        Click="AchPostBtn_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#15803D"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#86EFAC"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Fetch from Payrix button -->
                                <Button x:Name="AchFetchBtn" Grid.Column="16"
                                        Content="📥  Fetch" Height="32" Padding="12,0"
                                        FontWeight="SemiBold" FontSize="12" Cursor="Hand"
                                        BorderThickness="0" Background="#7C3AED" Foreground="White"
                                        Click="AchFetchBtn_Click"
                                        ToolTip="Fetch the most recent matching transaction from Payrix for the selected type and build the webhook payload">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#6D28D9"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#DDD6FE"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Status text — fills remaining space -->
                                <TextBlock x:Name="AchPostStatus" Grid.Column="18"
                                           FontSize="12" VerticalAlignment="Center"
                                           Foreground="{DynamicResource LabelFg}"
                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                           Text="← select type &amp; environment, then Send POST or Fetch from Payrix"
                                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                <!-- Hidden name alias so code-behind x:Name refs still compile -->
                                <TextBlock x:Name="WebhookConfigToggleText" Visibility="Collapsed"/>

                                <!-- ── Date filter row ── -->
                                <StackPanel x:Name="WebhookDateFilterPanel"
                                            Grid.Row="1" Grid.ColumnSpan="21"
                                            Orientation="Horizontal" Margin="0,8,0,0"
                                            Visibility="Collapsed">
                                    <TextBlock Text="Date filter:" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"
                                               Margin="0,0,8,0"
                                               ToolTip="Filter Fetch results by transaction created date (inclusive)"/>
                                    <TextBlock Text="From:" FontSize="12" Foreground="{DynamicResource SubLabelFg}"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <DatePicker x:Name="FetchFromDatePicker"
                                                Width="120" Height="30" FontSize="11"
                                                VerticalContentAlignment="Center"
                                                SelectedDateFormat="Short"
                                                ToolTip="Start of date range (inclusive) — leave blank for no lower bound"/>
                                    <TextBlock Text="To:" FontSize="12" Foreground="{DynamicResource SubLabelFg}"
                                               VerticalAlignment="Center" Margin="10,0,4,0"/>
                                    <DatePicker x:Name="FetchToDatePicker"
                                                Width="120" Height="30" FontSize="11"
                                                VerticalContentAlignment="Center"
                                                SelectedDateFormat="Short"
                                                ToolTip="End of date range (inclusive) — leave blank for no upper bound"/>
                                    <Button x:Name="FetchClearDatesBtn"
                                            Content="✕ Clear" Height="28" Padding="10,0"
                                            FontSize="11" Cursor="Hand" Margin="8,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource InputBorder}"
                                            Background="{DynamicResource CopyBtnBg}" Foreground="{DynamicResource SubLabelFg}"
                                            Click="FetchClearDatesBtn_Click"
                                            ToolTip="Clear date filter">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock x:Name="DateFilterHintText"
                                               FontSize="11" Foreground="{DynamicResource HintFg}"
                                               VerticalAlignment="Center" Margin="12,0,0,0"
                                               Text="(optional — narrows Fetch results by created date)"/>

                                    <!-- Search all webhooks by TxnID -->
                                    <Button x:Name="SearchAllWebhooksBtn"
                                            Content="🔍 Search All Webhooks" Height="28" Padding="10,0"
                                            FontSize="11" Cursor="Hand" Margin="16,0,0,0"
                                            BorderThickness="1" BorderBrush="#FDE68A"
                                            Background="#FFFBEB" Foreground="#92400E"
                                            Click="SearchAllWebhooksBtn_Click"
                                            ToolTip="Fetch the transaction/disbursement in txnId and build ALL webhook payloads from it">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <TextBlock x:Name="SearchAllStatusText"
                                               FontSize="11" Foreground="{DynamicResource SubLabelFg}"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Text=""/>

                                    <!-- Open log file -->
                                    <Button x:Name="OpenLogBtn"
                                            Content="📋 Open Log" Height="28" Padding="10,0"
                                            FontSize="11" Cursor="Hand" Margin="16,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource InfoStripBlueBorder}"
                                            Background="{DynamicResource QuickFetchCcBg}" Foreground="{DynamicResource QuickFetchCcFg}"
                                            Click="OpenLogBtn_Click"
                                            ToolTip="Open today's webhook log file in Notepad">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#E0F2FE"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                                <!-- ── Entity Custom Field (Row 2) — for Onboarding webhooks ── -->
                                <StackPanel x:Name="WebhookEntityCustomPanel"
                                            Grid.Row="2" Grid.ColumnSpan="21"
                                            Orientation="Horizontal" Margin="0,6,0,0"
                                            Visibility="Collapsed">
                                    <Border Background="{DynamicResource OrangePanelBg}" BorderBrush="{DynamicResource OrangePanelBorder}"
                                            BorderThickness="1" CornerRadius="5" Padding="8,5">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🏢" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Entity Custom:" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource OrangePanelFg}" VerticalAlignment="Center" Margin="0,0,8,0"
                                                       ToolTip="Used in Entities Created &amp; Merchant Boarded webhook payloads&#x0a;Format: AccountID,CompanyID  (comma-separated)"/>
                                            <ComboBox x:Name="EntityCustomBox"
                                                      IsEditable="True"
                                                      Width="380" Height="28" Padding="6,0"
                                                      FontFamily="Consolas" FontSize="11"
                                                      VerticalContentAlignment="Center"
                                                      BorderBrush="#FED7AA" BorderThickness="1"
                                                      ToolTip="AccountID,CompanyID — e.g. 5F523389-...,672209C4-...&#x0a;When multiple companies are found, use the dropdown to switch between them."/>
                                            <Button x:Name="UseDbIdsForCustomBtn"
                                                    Content="⟵ Use DB IDs" Height="28" Padding="10,0"
                                                    FontSize="11" Cursor="Hand" Margin="6,0,0,0"
                                                    BorderThickness="1" BorderBrush="#FED7AA"
                                                    Background="#FFFBEB" Foreground="#92400E"
                                                    Click="UseDbIdsForCustomBtn_Click"
                                                    ToolTip="Auto-fill from the AccountID + CompanyID shown in the Core DB strip">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <!-- Fetch AccountID+CompanyID directly from host DB by email -->
                                            <Button x:Name="FetchEntityCustomFromDbBtn"
                                                    Content="🔍 Fetch from DB" Height="28" Padding="10,0"
                                                    FontSize="11" Cursor="Hand" Margin="6,0,0,0"
                                                    BorderThickness="1" BorderBrush="#FED7AA"
                                                    Background="#FFF7ED" Foreground="#92400E"
                                                    Click="FetchEntityCustomFromDbBtn_Click"
                                                    ToolTip="Fetch AccountID + CompanyID from Local BQECoreHost DB using the Email in the DB config panel, then fill this box">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <TextBlock x:Name="EntityCustomHint"
                                                       FontSize="11" Foreground="{DynamicResource HintFg}"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                                       Text="← used in Entities Created &amp; Merchant Boarded payloads"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- ── Host DB connection strings (Row 3) ── -->
                                <ScrollViewer x:Name="WebhookDbConfigPanel"
                                              Grid.Row="3" Grid.ColumnSpan="21"
                                              Margin="0,8,0,0"
                                              Visibility="Collapsed"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto"
                                              MaxHeight="160">
                                    <StackPanel Orientation="Vertical" VerticalAlignment="Top">
                                        <!-- Hidden — kept for code-behind compatibility -->
                                        <TextBlock x:Name="AutoDetectStatusText" Visibility="Collapsed" Height="0"/>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top">

                                        <!-- Payment Service DB -->
                                        <Border BorderBrush="{DynamicResource DbConfigBorder}" BorderThickness="1"
                                                CornerRadius="6" Padding="10,6" Margin="0,0,12,0"
                                                Background="{DynamicResource DbConfigBg}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="52"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="380"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="22"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Row="0" Grid.ColumnSpan="5"
                                                           Text="🗄  Payment Service DB  (CompanyID)"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource LabelFg}" Margin="0,0,0,4"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Local"
                                                           FontSize="11" Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="LocalHostDbBox" Grid.Row="1" Grid.Column="2"
                                                         Height="22" Padding="5,0" FontFamily="Consolas" FontSize="10"
                                                         VerticalContentAlignment="Center" Margin="0,2,0,2"
                                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                         ToolTip="Local BQECorePaymentService DB"/>
                                                <Button Grid.Row="1" Grid.Column="4" Content="⧉" Height="22" Width="22"
                                                        Padding="0" FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                                                        BorderThickness="1" BorderBrush="{DynamicResource CopyBtnBorder}" Background="{DynamicResource CopyBtnBg}"
                                                        ToolTip="Copy Local Payment Service DB connection string"
                                                        Click="CopyLocalHostDbBtn_Click">
                                                    <Button.Template><ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/></Trigger></ControlTemplate.Triggers>
                                                    </ControlTemplate></Button.Template>
                                                </Button>
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Staging"
                                                           FontSize="11" Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="StagingHostDbBox" Grid.Row="2" Grid.Column="2"
                                                         Height="22" Padding="5,0" FontFamily="Consolas" FontSize="10"
                                                         VerticalContentAlignment="Center" Margin="0,2,0,2"
                                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                         ToolTip="Staging BQECorePaymentService DB"/>
                                                <Button Grid.Row="2" Grid.Column="4" Content="⧉" Height="22" Width="22"
                                                        Padding="0" FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                                                        BorderThickness="1" BorderBrush="{DynamicResource CopyBtnBorder}" Background="{DynamicResource CopyBtnBg}"
                                                        ToolTip="Copy Staging Payment Service DB connection string"
                                                        Click="CopyStagingHostDbBtn_Click">
                                                    <Button.Template><ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/></Trigger></ControlTemplate.Triggers>
                                                    </ControlTemplate></Button.Template>
                                                </Button>
                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Sprint"
                                                           FontSize="11" Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="SprintHostDbBox" Grid.Row="3" Grid.Column="2"
                                                         Height="22" Padding="5,0" FontFamily="Consolas" FontSize="10"
                                                         VerticalContentAlignment="Center" Margin="0,2,0,2"
                                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                         ToolTip="Sprint BQECorePaymentService DB"/>
                                                <Button Grid.Row="3" Grid.Column="4" Content="⧉" Height="22" Width="22"
                                                        Padding="0" FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                                                        BorderThickness="1" BorderBrush="{DynamicResource CopyBtnBorder}" Background="{DynamicResource CopyBtnBg}"
                                                        ToolTip="Copy Sprint Payment Service DB connection string"
                                                        Click="CopySprintHostDbBtn_Click">
                                                    <Button.Template><ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/></Trigger></ControlTemplate.Triggers>
                                                    </ControlTemplate></Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>

                                        <!-- Main Host DB -->
                                        <Border BorderBrush="{DynamicResource DbConfigBlueBorder}" BorderThickness="1"
                                                CornerRadius="6" Padding="10,6"
                                                Background="{DynamicResource DbConfigBlueBg}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="52"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="380"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="22"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Row="0" Grid.ColumnSpan="5"
                                                           Text="🗄  Main Host DB  (AccountID)"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource InfoStripBlueFg}" Margin="0,0,0,4"/>
                                                <!-- Core Account Email for Account.Email lookup -->
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Email"
                                                           FontSize="11" Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="CoreAccountEmailBox" Grid.Row="1" Grid.Column="2"
                                                         Height="22" Padding="5,0" FontSize="11"
                                                         VerticalContentAlignment="Center" Margin="0,2,0,4"
                                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                         ToolTip="Email in Account table — used to look up AccountID (e.g. Shaheen@bqe.com)"
                                                         Text="Shaheen@bqe.com"/>
                                                <!-- Fetch button — queries main DB by email, shows AccountID + CompanyID -->
                                                <Button x:Name="FetchIdsByEmailBtn"
                                                        Grid.Row="1" Grid.Column="4"
                                                        Content="▶" Height="22" Width="22"
                                                        Padding="0" FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                                                        BorderThickness="1" BorderBrush="{DynamicResource InfoStripBlueBorder}"
                                                        Background="{DynamicResource InfoStripBlueBtnBg}"
                                                        Foreground="{DynamicResource InfoStripBlueFg}"
                                                        ToolTip="Fetch AccountID and CompanyID for this email from the Local main DB"
                                                        Click="FetchIdsByEmailBtn_Click">
                                                    <Button.Template><ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource InfoStripBlueBtnHover}"/></Trigger></ControlTemplate.Triggers>
                                                    </ControlTemplate></Button.Template>
                                                </Button>
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Local"
                                                           FontSize="11" Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="LocalMainDbBox" Grid.Row="2" Grid.Column="2"
                                                         Height="22" Padding="5,0" FontFamily="Consolas" FontSize="10"
                                                         VerticalContentAlignment="Center" Margin="0,2,0,2"
                                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                         ToolTip="Local BQECoreHost main DB"/>
                                                <Button Grid.Row="2" Grid.Column="4" Content="⧉" Height="22" Width="22"
                                                        Padding="0" FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                                                        BorderThickness="1" BorderBrush="{DynamicResource InfoStripBlueBorder}" Background="{DynamicResource CopyBtnBg}"
                                                        ToolTip="Copy Local Main DB connection string"
                                                        Click="CopyLocalMainDbBtn_Click">
                                                    <Button.Template><ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource InfoStripBlueBtnHover}"/></Trigger></ControlTemplate.Triggers>
                                                    </ControlTemplate></Button.Template>
                                                </Button>
                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Staging"
                                                           FontSize="11" Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="StagingMainDbBox" Grid.Row="3" Grid.Column="2"
                                                         Height="22" Padding="5,0" FontFamily="Consolas" FontSize="10"
                                                         VerticalContentAlignment="Center" Margin="0,2,0,2"
                                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                         ToolTip="Staging BQECoreHost main DB"/>
                                                <Button Grid.Row="3" Grid.Column="4" Content="⧉" Height="22" Width="22"
                                                        Padding="0" FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                                                        BorderThickness="1" BorderBrush="{DynamicResource InfoStripBlueBorder}" Background="{DynamicResource CopyBtnBg}"
                                                        ToolTip="Copy Staging Main DB connection string"
                                                        Click="CopyStagingMainDbBtn_Click">
                                                    <Button.Template><ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource InfoStripBlueBtnHover}"/></Trigger></ControlTemplate.Triggers>
                                                    </ControlTemplate></Button.Template>
                                                </Button>
                                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Sprint"
                                                           FontSize="11" Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="SprintMainDbBox" Grid.Row="4" Grid.Column="2"
                                                         Height="22" Padding="5,0" FontFamily="Consolas" FontSize="10"
                                                         VerticalContentAlignment="Center" Margin="0,2,0,2"
                                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                         ToolTip="Sprint BQECoreHost main DB"/>
                                                <Button Grid.Row="4" Grid.Column="4" Content="⧉" Height="22" Width="22"
                                                        Padding="0" FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                                                        BorderThickness="1" BorderBrush="{DynamicResource InfoStripBlueBorder}" Background="{DynamicResource CopyBtnBg}"
                                                        ToolTip="Copy Sprint Main DB connection string"
                                                        Click="CopySprintMainDbBtn_Click">
                                                    <Button.Template><ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource InfoStripBlueBtnHover}"/></Trigger></ControlTemplate.Triggers>
                                                    </ControlTemplate></Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>

                                        </StackPanel><!-- end horizontal DB panels -->
                                    </StackPanel><!-- end vertical wrapper -->
                                </ScrollViewer>

                                <!-- ── AccountID / CompanyID info strip (Row 5) — always below config rows ── -->
                                <StackPanel Grid.Row="5" Grid.ColumnSpan="21" Orientation="Horizontal"
                                            Margin="0,4,0,0" Visibility="Collapsed"
                                            x:Name="EntityInfoPanel">
                                    <TextBlock Text="🏢" FontSize="13" VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <TextBlock Text="Account ID:" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <Border Background="{DynamicResource InfoBoxBg}" BorderBrush="{DynamicResource InfoStripGreenBorder}"
                                            BorderThickness="1" CornerRadius="4" Padding="8,3">
                                        <TextBlock x:Name="EntityAccountIdText"
                                                   FontFamily="Consolas" FontSize="12"
                                                   Foreground="{DynamicResource InfoStripGreenFg}" VerticalAlignment="Center"
                                                   Text="—"
                                                   ToolTip="AccountID from Payrix entity custom field"/>
                                    </Border>
                                    <Button Content="⧉" Height="22" Width="22" Padding="0"
                                            FontSize="11" Cursor="Hand" Margin="4,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource InfoStripGreenBorder}"
                                            Background="{DynamicResource InfoStripGreenBtnBg}" Foreground="{DynamicResource InfoStripGreenFg}"
                                            Click="CopyEntityAccountIdBtn_Click"
                                            ToolTip="Copy Account ID">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource InfoStripGreenBtnHover}"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock Text="Company ID:" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"
                                               Margin="14,0,6,0"/>
                                    <Border Background="{DynamicResource InfoBoxBg}" BorderBrush="{DynamicResource InfoStripGreenBorder}"
                                            BorderThickness="1" CornerRadius="4" Padding="8,3">
                                        <TextBlock x:Name="EntityCompanyIdText"
                                                   FontFamily="Consolas" FontSize="12"
                                                   Foreground="{DynamicResource InfoStripGreenFg}" VerticalAlignment="Center"
                                                   Text="—"
                                                   ToolTip="CompanyID from Payrix entity custom field"/>
                                    </Border>
                                    <Button Content="⧉" Height="22" Width="22" Padding="0"
                                            FontSize="11" Cursor="Hand" Margin="4,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource InfoStripGreenBorder}"
                                            Background="{DynamicResource InfoStripGreenBtnBg}" Foreground="{DynamicResource InfoStripGreenFg}"
                                            Click="CopyEntityCompanyIdBtn_Click"
                                            ToolTip="Copy Company ID">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource InfoStripGreenBtnHover}"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock x:Name="EntityIdText"
                                               FontSize="11" Foreground="{DynamicResource SubLabelFg}"
                                               VerticalAlignment="Center" Margin="12,0,0,0"
                                               Text=""/>
                                    <Button Content="📋 Copy Both" Height="24" Padding="8,0"
                                            FontSize="11" Cursor="Hand" Margin="10,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource InfoStripGreenBorder}"
                                            Background="{DynamicResource InfoStripGreenBtnBg}" Foreground="{DynamicResource InfoStripGreenFg}"
                                            Click="CopyEntityIdsBtn_Click"
                                            ToolTip="Copy AccountID and CompanyID to clipboard">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource InfoStripGreenBtnHover}"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                                <!-- ── Host DB result strip (Row 4) ── -->
                                <StackPanel Grid.Row="4" Orientation="Horizontal"
                                            Margin="0,4,0,0" Visibility="Collapsed"
                                            x:Name="HostDbInfoPanel">
                                    <TextBlock Text="🗄" FontSize="13" VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <TextBlock Text="Core DB  ›  Account ID:" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <Border Background="{DynamicResource InfoBoxBg}" BorderBrush="{DynamicResource InfoStripBlueBorder}"
                                            BorderThickness="1" CornerRadius="4" Padding="8,3">
                                        <TextBlock x:Name="HostDbAccountIdText"
                                                   FontFamily="Consolas" FontSize="12"
                                                   Foreground="{DynamicResource InfoStripBlueFg}" VerticalAlignment="Center"
                                                   Text="—"
                                                   ToolTip="AccountID from BQECoreHost DB"/>
                                    </Border>
                                    <Button Content="⧉" Height="22" Width="22" Padding="0"
                                            FontSize="11" Cursor="Hand" Margin="4,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource InfoStripBlueBorder}"
                                            Background="{DynamicResource InfoStripBlueBtnBg}" Foreground="{DynamicResource InfoStripBlueFg}"
                                            Click="CopyHostDbAccountIdBtn_Click"
                                            ToolTip="Copy Account ID">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource InfoStripBlueBtnHover}"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock Text="Company ID:" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"
                                               Margin="14,0,6,0"/>
                                    <Border Background="{DynamicResource InfoBoxBg}" BorderBrush="{DynamicResource InfoStripBlueBorder}"
                                            BorderThickness="1" CornerRadius="4" Padding="8,3">
                                        <TextBlock x:Name="HostDbCompanyIdText"
                                                   FontFamily="Consolas" FontSize="12"
                                                   Foreground="{DynamicResource InfoStripBlueFg}" VerticalAlignment="Center"
                                                   Text="—"
                                                   ToolTip="CoreCompany_ID from BQECoreHost DB"/>
                                    </Border>
                                    <Button Content="⧉" Height="22" Width="22" Padding="0"
                                            FontSize="11" Cursor="Hand" Margin="4,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource InfoStripBlueBorder}"
                                            Background="{DynamicResource InfoStripBlueBtnBg}" Foreground="{DynamicResource InfoStripBlueFg}"
                                            Click="CopyHostDbCompanyIdBtn_Click"
                                            ToolTip="Copy Company ID">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource InfoStripBlueBtnHover}"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock x:Name="HostDbSourceText"
                                               FontSize="11" Foreground="{DynamicResource SubLabelFg}"
                                               VerticalAlignment="Center" Margin="12,0,0,0"
                                               Text=""/>
                                    <Button Content="📋 Copy Both" Height="24" Padding="8,0"
                                            FontSize="11" Cursor="Hand" Margin="10,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource InfoStripBlueBorder}"
                                            Background="{DynamicResource InfoStripBlueBtnBg}" Foreground="{DynamicResource InfoStripBlueFg}"
                                            Click="CopyHostDbIdsBtn_Click"
                                            ToolTip="Copy AccountID and CompanyID to clipboard">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource InfoStripBlueBtnHover}"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        </ScrollViewer>

                        <!-- ── Transaction Detail Card (compact single row) ──── -->
                        <Border x:Name="TxnDetailCard" Grid.Row="1"
                                Visibility="Collapsed"
                                Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                                BorderThickness="1" CornerRadius="8" Margin="0,0,0,8" Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/><!-- Left badge panel -->
                                    <ColumnDefinition Width="*"/> <!-- 5 tiles -->
                                </Grid.ColumnDefinitions>

                                <!-- Left colored badge — horizontal compact -->
                                <Border x:Name="TxnCardLeftPanel" Grid.Column="0"
                                        Background="#4F46E5" CornerRadius="8,0,0,8" Padding="14,10">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock x:Name="TxnCardIcon" Text="🏦"
                                                   FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock x:Name="TxnCardTypeLabel" Text="ACH RETURN"
                                                       FontSize="12" FontWeight="Bold" Foreground="White"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <Border x:Name="TxnCardStatusBadge"
                                                        Background="#16A34A" CornerRadius="8" Padding="6,2"
                                                        Margin="0,0,6,0">
                                                    <TextBlock x:Name="TxnCardStatusBadgeText" Text="Processed"
                                                               FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                                <TextBlock x:Name="TxnCardStatusText" Text="✓ Settled"
                                                           FontSize="9" Foreground="#86EFAC" FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock x:Name="TxnCardSubType" Text="Type: ACH Return"
                                                       FontSize="9" Foreground="#C4B5FD" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Right: 5 tiles in a single row -->
                                <Grid Grid.Column="1" Margin="10,8,10,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/><!-- TxnID wider -->
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Tile: Transaction ID -->
                                    <Border Grid.Column="0"
                                            Background="{DynamicResource TileCardBg}" BorderBrush="{DynamicResource CardBorder}"
                                            BorderThickness="1" CornerRadius="5" Padding="8,6">
                                        <StackPanel>
                                            <TextBlock Text="TRANSACTION ID" FontSize="8" FontWeight="Bold"
                                                       Foreground="{DynamicResource SubText}" Margin="0,0,0,3"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="TxnCardId" Text="—"
                                                           FontFamily="Consolas" FontSize="10"
                                                           Foreground="{DynamicResource PrimaryText}"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" x:Name="CopyTxnCardIdBtn"
                                                        Content="⧉" Width="18" Height="18" Padding="0"
                                                        FontSize="10" Cursor="Hand" Margin="3,0,0,0"
                                                        BorderThickness="1" BorderBrush="{DynamicResource CopyBtnBorder}"
                                                        Background="{DynamicResource CopyBtnBg}" Foreground="{DynamicResource SubText}"
                                                        ToolTip="Copy Transaction ID"
                                                        Click="CopyTxnCardIdBtn_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="3">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Tile: Amount -->
                                    <Border Grid.Column="2"
                                            Background="{DynamicResource TileCardBg}" BorderBrush="{DynamicResource CardBorder}"
                                            BorderThickness="1" CornerRadius="5" Padding="8,6">
                                        <StackPanel>
                                            <TextBlock Text="AMOUNT" FontSize="8" FontWeight="Bold"
                                                       Foreground="{DynamicResource SubText}" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxnCardAmount" Text="—"
                                                       FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                                       Foreground="#16A34A"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Tile: Timestamp -->
                                    <Border Grid.Column="4"
                                            Background="{DynamicResource TileCardBg}" BorderBrush="{DynamicResource CardBorder}"
                                            BorderThickness="1" CornerRadius="5" Padding="8,6">
                                        <StackPanel>
                                            <TextBlock Text="TIMESTAMP" FontSize="8" FontWeight="Bold"
                                                       Foreground="{DynamicResource SubText}" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxnCardTimestamp" Text="—"
                                                       FontSize="10" Foreground="{DynamicResource PrimaryText}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Tile: Descriptor -->
                                    <Border Grid.Column="6"
                                            Background="{DynamicResource TileCardBg}" BorderBrush="{DynamicResource CardBorder}"
                                            BorderThickness="1" CornerRadius="5" Padding="8,6">
                                        <StackPanel>
                                            <TextBlock Text="DESCRIPTOR" FontSize="8" FontWeight="Bold"
                                                       Foreground="{DynamicResource SubText}" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxnCardDescriptor" Text="—"
                                                       FontSize="10" Foreground="{DynamicResource PrimaryText}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Tile: Payment Type -->
                                    <Border Grid.Column="8"
                                            Background="{DynamicResource TileCardBg}" BorderBrush="{DynamicResource CardBorder}"
                                            BorderThickness="1" CornerRadius="5" Padding="8,6">
                                        <StackPanel>
                                            <TextBlock Text="PAYMENT TYPE" FontSize="8" FontWeight="Bold"
                                                       Foreground="{DynamicResource SubText}" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxnCardPaymentType" Text="—"
                                                       FontSize="10" Foreground="{DynamicResource PrimaryText}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Controls row -->
                        <Grid Grid.Row="2" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Endpoint:" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="WebhookEnvBox" Grid.Column="1" Height="30"
                                      VerticalContentAlignment="Center" FontSize="12"
                                      SelectionChanged="WebhookEnvBox_SelectionChanged" SelectedIndex="0">
                                <ComboBoxItem Content="Local"/>
                                <ComboBoxItem Content="Staging"/>
                                <ComboBoxItem Content="Sprint"/>
                                <ComboBoxItem Content="Production"/>
                                <ComboBoxItem Content="Custom"/>
                            </ComboBox>

                            <TextBlock Grid.Column="3" Text="URL:" FontSize="11" Foreground="{DynamicResource SubLabelFg}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="WebhookUrlBox" Grid.Column="4" Height="30" Padding="8,0"
                                     VerticalContentAlignment="Center" FontSize="11" FontFamily="Consolas"
                                     BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"/>

                            <Button x:Name="RunAllTestsBtn" Grid.Column="6"
                                    Content="▶  Run All Tests"
                                    Click="RunAllTestsBtn_Click"
                                    Style="{StaticResource SecondaryButton}"
                                    ToolTip="Run all webhook test cases against the selected endpoint"/>
                            <Button x:Name="ResetTestsBtn" Grid.Column="8"
                                    Content="↺  Reset"
                                    Click="ResetTestsBtn_Click"
                                    ToolTip="Reset all test results to their initial state">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource LabelFg}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- Config toggle — lives here so it is NEVER pushed off screen -->
                            <Border x:Name="WebhookConfigToggleBorder2" Grid.Column="10"
                                    Cursor="Hand" CornerRadius="6" Padding="10,6"
                                    Background="{DynamicResource WebhookConfigBg}" BorderBrush="{DynamicResource WebhookConfigBorder}" BorderThickness="1"
                                    MouseLeftButtonUp="WebhookConfigToggle_Click"
                                    ToolTip="Show / hide date filter, entity custom field and DB connection strings">
                                <TextBlock x:Name="WebhookConfigToggleText2"
                                           Text="⚙ Config ▼" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource WebhookConfigFg}"/>
                            </Border>
                        </Grid>

                        <!-- ── Results + Summary + Payload wrapper ── -->
                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" MinHeight="120"/><!-- inner Row 0: results -->
                                <RowDefinition Height="Auto"/>             <!-- inner Row 1: summary -->
                                <RowDefinition Height="170"/>              <!-- inner Row 2: payload (fixed) -->
                            </Grid.RowDefinitions>

                        <!-- Results grid -->
                        <DataGrid x:Name="TestResultsGrid" Grid.Row="0"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserResizeColumns="True" GridLinesVisibility="Horizontal"
                                  AlternatingRowBackground="{DynamicResource GridAltRowBg}" RowBackground="{DynamicResource GridRowBg}"
                                  HeadersVisibility="Column" BorderThickness="1" BorderBrush="{DynamicResource CardBorder2}"
                                  SelectionUnit="FullRow" SelectionMode="Single"
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                  FontSize="12" SelectionChanged="TestResultsGrid_SelectionChanged">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{DynamicResource GridHeaderBg}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource GridHeaderFg}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource GridBorder}"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="{DynamicResource GridRowBg}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static local:TestStatus.Pass}">
                                            <Setter Property="Background" Value="{DynamicResource TestRowPassBg}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static local:TestStatus.Fail}">
                                            <Setter Property="Background" Value="{DynamicResource TestRowFailBg}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static local:TestStatus.Running}">
                                            <Setter Property="Background" Value="{DynamicResource TestRowRunningBg}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Status" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F1F5F9"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static local:TestStatus.Pass}">
                                                                <Setter Property="Background" Value="#DCFCE7"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static local:TestStatus.Fail}">
                                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static local:TestStatus.Running}">
                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding StatusLabel}" FontWeight="Bold" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#6B7280"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static local:TestStatus.Pass}">
                                                                    <Setter Property="Foreground" Value="#166534"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static local:TestStatus.Fail}">
                                                                    <Setter Property="Foreground" Value="#991B1B"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static local:TestStatus.Running}">
                                                                    <Setter Property="Foreground" Value="#92400E"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Test Name"   Binding="{Binding Name}"       Width="*"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="260"/>
                                <DataGridTextColumn Header="HTTP"        Binding="{Binding HttpCode}"    Width="55"/>
                                <DataGridTextColumn Header="ms"          Binding="{Binding DurationMs}"  Width="55"/>
                                <DataGridTextColumn Header="Detail"      Binding="{Binding Detail}"      Width="220"/>
                                <DataGridTemplateColumn Header="Run" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="▶ Run"
                                                    Tag="{Binding}"
                                                    Click="RunSingleTestBtn_Click"
                                                    Height="26" Padding="8,0"
                                                    FontSize="11" FontWeight="SemiBold"
                                                    Cursor="Hand" BorderThickness="0"
                                                    Background="#4F46E5" Foreground="White"
                                                    Margin="4,2">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#4338CA"/>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Background" Value="#A5B4FC"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Summary bar -->
                        <Border Grid.Row="1" Background="{DynamicResource SummaryBarBg}" BorderBrush="{DynamicResource SummaryBarBorder}"
                                BorderThickness="1" CornerRadius="6" Padding="12,4" Margin="0,5,0,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="WebhookTestSummary"
                                           Text="Select an environment and click Run All Tests"
                                           FontSize="12" Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="WebhookTestProgress"
                                           Grid.Column="1" FontSize="11" Foreground="{DynamicResource SubText}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Payload panel (editable + toolbar) -->
                        <Border Grid.Row="2" BorderBrush="{DynamicResource CardBorder2}" BorderThickness="1" CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Toolbar -->
                                <Border Grid.Row="0" Background="#1E293B" CornerRadius="6,6,0,0" Padding="8,5">
                                    <StackPanel>
                                        <!-- Title row + action buttons -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="JSON Payload  (editable)"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="#94A3B8" VerticalAlignment="Center"/>
                                            <Border x:Name="ReplaceToggleBorder"
                                                    Cursor="Hand" CornerRadius="3" Padding="6,2" Margin="10,0,0,0"
                                                    Background="#334155" BorderBrush="#475569" BorderThickness="1"
                                                    MouseLeftButtonUp="ReplaceRowToggle_Click"
                                                    ToolTip="Show / hide the field-replace bar">
                                                <TextBlock x:Name="ReplaceToggleText" Text="🔄 Replace ▼"
                                                           FontSize="10" Foreground="#94A3B8"/>
                                            </Border>
                                        </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,2,0">
                                            <Button Content="📋 Copy All"
                                                    Click="WebhookPayloadCopyAll_Click"
                                                    Height="24" Padding="8,0" Margin="0,0,4,0"
                                                    FontSize="11" Cursor="Hand" BorderThickness="0"
                                                    Background="#334155" Foreground="#E2E8F0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#475569"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button Content="📌 Paste (Replace All)"
                                                    Click="WebhookPayloadPaste_Click"
                                                    Height="24" Padding="8,0" Margin="0,0,4,0"
                                                    FontSize="11" Cursor="Hand" BorderThickness="0"
                                                    Background="#334155" Foreground="#E2E8F0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#475569"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button Content="🗑 Clear"
                                                    Click="WebhookPayloadClear_Click"
                                                    Height="24" Padding="8,0" Margin="0,0,4,0"
                                                    FontSize="11" Cursor="Hand" BorderThickness="0"
                                                    Background="#334155" Foreground="#E2E8F0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#475569"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button Content="⎌ Undo"
                                                    Click="PayloadUndoBtn_Click"
                                                    Height="24" Padding="8,0"
                                                    FontSize="11" Cursor="Hand" BorderThickness="0"
                                                    Background="#334155" Foreground="#E2E8F0"
                                                    ToolTip="Undo last programmatic change to payload">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#475569"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                        </Grid>

                                        <!-- Replace field row (hidden by default) -->
                                        <StackPanel x:Name="ReplaceFieldPanel"
                                                    Orientation="Horizontal" Margin="0,5,0,0"
                                                    Visibility="Collapsed">
                                            <TextBlock Text="Replace field:" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SubText}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBox x:Name="ReplaceFieldNameBox"
                                                     Width="120" Height="24" Padding="6,0"
                                                     FontFamily="Consolas" FontSize="11"
                                                     Background="#334155" Foreground="#E2E8F0"
                                                     CaretBrush="White" BorderBrush="#475569" BorderThickness="1"
                                                     VerticalContentAlignment="Center"
                                                     ToolTip="JSON field name to replace (e.g.  custom  or  email)"/>
                                            <TextBlock Text="→" FontSize="13" Foreground="#64748B"
                                                       VerticalAlignment="Center" Margin="6,0"/>
                                            <TextBox x:Name="ReplaceFieldValueBox"
                                                     Width="280" Height="24" Padding="6,0"
                                                     FontFamily="Consolas" FontSize="11"
                                                     Background="#334155" Foreground="#E2E8F0"
                                                     CaretBrush="White" BorderBrush="#475569" BorderThickness="1"
                                                     VerticalContentAlignment="Center"
                                                     ToolTip="New value to set (string, number or null — quotes added automatically for strings)"/>
                                            <Button Content="✔ Apply"
                                                    Click="ReplaceFieldBtn_Click"
                                                    Height="24" Padding="10,0" Margin="6,0,0,0"
                                                    FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                                    BorderThickness="0" Background="#4F46E5" Foreground="White">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#4338CA"/></Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <!-- Quick-fill chips -->
                                            <TextBlock Text="Quick:" FontSize="10" Foreground="#64748B"
                                                       VerticalAlignment="Center" Margin="12,0,4,0"/>
                                            <Button Content="custom"   Tag="custom"   Click="QuickFieldChip_Click" Height="22" Padding="7,0" Margin="0,0,3,0" FontSize="10" Cursor="Hand" BorderThickness="1" BorderBrush="#475569" Background="#1E293B" Foreground="{DynamicResource SubText}"><Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#334155"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                            <Button Content="email"    Tag="email"    Click="QuickFieldChip_Click" Height="22" Padding="7,0" Margin="0,0,3,0" FontSize="10" Cursor="Hand" BorderThickness="1" BorderBrush="#475569" Background="#1E293B" Foreground="{DynamicResource SubText}"><Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#334155"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                            <Button Content="name"     Tag="name"     Click="QuickFieldChip_Click" Height="22" Padding="7,0" Margin="0,0,3,0" FontSize="10" Cursor="Hand" BorderThickness="1" BorderBrush="#475569" Background="#1E293B" Foreground="{DynamicResource SubText}"><Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#334155"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                            <Button Content="id"       Tag="id"       Click="QuickFieldChip_Click" Height="22" Padding="7,0" Margin="0,0,3,0" FontSize="10" Cursor="Hand" BorderThickness="1" BorderBrush="#475569" Background="#1E293B" Foreground="{DynamicResource SubText}"><Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#334155"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                            <Button Content="txnId"    Tag="txnId"    Click="QuickFieldChip_Click" Height="22" Padding="7,0" Margin="0,0,0,0" FontSize="10" Cursor="Hand" BorderThickness="1" BorderBrush="#475569" Background="#1E293B" Foreground="{DynamicResource SubText}"><Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#334155"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                            <TextBlock x:Name="ReplaceFieldStatus" FontSize="11" Foreground="#4ADE80"
                                                       VerticalAlignment="Center" Margin="10,0,0,0" Text=""/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Editable JSON box -->
                                <TextBox x:Name="WebhookPayloadBox" Grid.Row="1"
                                         IsReadOnly="False"
                                         FontFamily="Consolas" FontSize="11"
                                         Background="{DynamicResource CodeBg}" Foreground="{DynamicResource CodeFg}"
                                         CaretBrush="White" SelectionBrush="#4F46E5"
                                         BorderThickness="0"
                                         Padding="10" TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         AcceptsReturn="True" AcceptsTab="True"
                                         SpellCheck.IsEnabled="False"/>
                            </Grid>
                        </Border>
                        </Grid><!-- end Results+Summary+Payload wrapper -->
                    </Grid>
                </TabItem>

                <!-- Raw JSON Tab -->
                <TabItem Header="Raw JSON">
                    <DockPanel Background="{DynamicResource CodeBg}">

                        <!-- Toolbar pinned to top -->
                        <Border DockPanel.Dock="Top" Background="#1E293B" Padding="10,6"
                                BorderBrush="#334155" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="📋  Copy All" Click="RawJsonCopyAll_Click"
                                            Style="{StaticResource PrimaryButton}"
                                            Padding="12,5" FontSize="12" Margin="0,0,8,0"
                                            ToolTip="Copy entire Raw JSON to clipboard"/>
                                    <Button Content="📌  Paste JSON" Click="RawJsonPaste_Click"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="12,5" FontSize="12" Margin="0,0,8,0"
                                            ToolTip="Paste JSON from clipboard into this box"/>
                                    <Button Content="🗑️  Clear" Click="RawJsonClear_Click"
                                            Style="{StaticResource DangerButton}"
                                            Padding="12,5" FontSize="12" Margin="0,0,8,0"
                                            ToolTip="Clear the Raw JSON box"/>
                                    <Button Content="⎌  Undo" Click="RawJsonUndoBtn_Click"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="12,5" FontSize="12" Margin="0,0,8,0"
                                            ToolTip="Undo last change to Raw JSON (Ctrl+Z also works for typed text)"/>
                                    <Button Content="🔗  Share" Click="ShareRawJsonBtn_Click"
                                            Height="26" Padding="8,0" FontSize="11" Cursor="Hand" Margin="0,0,16,0"
                                            Background="#F0F9FF" Foreground="#007AFF"
                                            BorderBrush="#BAE6FD" BorderThickness="1">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#E0F2FE"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock Text="Tip: Ctrl+A · Ctrl+C · Ctrl+H = Find/Replace"
                                               FontSize="11" Foreground="#475569" VerticalAlignment="Center"
                                               FontFamily="Consolas"/>
                                </StackPanel>
                                <!-- Find/Replace toggle -->
                                <Button Grid.Column="1" Content="🔍  Find / Replace"
                                        Click="RawJsonFindReplaceToggle_Click"
                                        Height="28" Padding="10,0" FontSize="11"
                                        Cursor="Hand" BorderThickness="1"
                                        BorderBrush="#475569" Background="#334155" Foreground="#94A3B8">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#475569"/>
                                                    <Setter Property="Foreground" Value="#E2E8F0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Find & Replace bar (hidden by default, Ctrl+H or button to show) -->
                        <Border x:Name="RawJsonFindReplaceBar" DockPanel.Dock="Top"
                                Background="#162032" Padding="10,7"
                                BorderBrush="#334155" BorderThickness="0,0,0,1"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Find label + box -->
                                <TextBlock Grid.Column="0" Text="Find:" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBox x:Name="RawFindBox" Grid.Column="1" Height="26" Padding="7,0"
                                         Background="#1E293B" Foreground="#E2E8F0" CaretBrush="#E2E8F0"
                                         BorderBrush="#475569" BorderThickness="1"
                                         FontFamily="Consolas" FontSize="11" VerticalContentAlignment="Center"
                                         ToolTip="Text to search for (case-insensitive)"
                                         KeyDown="RawFindBox_KeyDown"/>

                                <!-- Replace label + box -->
                                <TextBlock Grid.Column="3" Text="Replace:" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBox x:Name="RawReplaceBox" Grid.Column="4" Height="26" Padding="7,0"
                                         Background="#1E293B" Foreground="#E2E8F0" CaretBrush="#E2E8F0"
                                         BorderBrush="#475569" BorderThickness="1"
                                         FontFamily="Consolas" FontSize="11" VerticalContentAlignment="Center"
                                         ToolTip="Replacement text"/>

                                <!-- Find Next -->
                                <Button Grid.Column="6" Content="🔍 Find Next" Height="26" Padding="10,0"
                                        FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                        BorderThickness="0" Background="#4F46E5" Foreground="White"
                                        Click="RawJsonFindNext_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#4338CA"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Replace (single) -->
                                <Button Grid.Column="8" Content="✏ Replace" Height="26" Padding="10,0"
                                        FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                        BorderThickness="0" Background="#059669" Foreground="White"
                                        Click="RawJsonReplace_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#047857"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Replace All -->
                                <Button Grid.Column="10" Content="🔁 Replace All" Height="26" Padding="10,0"
                                        FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                        BorderThickness="0" Background="#D97706" Foreground="White"
                                        Click="RawJsonReplaceAll_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#B45309"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Status text -->
                                <TextBlock x:Name="RawFindStatus" Grid.Column="11"
                                           FontSize="11" FontFamily="Consolas"
                                           Foreground="#64748B" VerticalAlignment="Center"
                                           Margin="12,0,0,0" Text=""/>

                                <!-- Close × -->
                                <Button Grid.Column="12" Content="✕" Height="22" Width="22" Padding="0"
                                        FontSize="12" Cursor="Hand" VerticalAlignment="Center"
                                        BorderThickness="0" Background="Transparent" Foreground="#64748B"
                                        Click="RawJsonFindReplaceClose_Click"
                                        ToolTip="Close Find/Replace bar">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="#E2E8F0"/>
                                                    <Setter Property="Background" Value="#334155"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Editable JSON area -->
                        <TextBox x:Name="RawJsonBox" FontFamily="Consolas" FontSize="12"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 Background="{DynamicResource CodeBg}" Foreground="{DynamicResource CodeFg}"
                                 BorderThickness="0" Padding="16" TextWrapping="NoWrap"
                                 AcceptsReturn="True" AcceptsTab="True"
                                 PreviewKeyDown="RawJsonBox_PreviewKeyDown"/>
                    </DockPanel>
                </TabItem>

                <!-- JSON Tools Tab -->
                <TabItem Header="🔧 JSON Tools">
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: JSON Formatter -->
                        <Border Grid.Column="0" Background="{DynamicResource CardBg}" CornerRadius="10" Padding="14">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.07" Color="#64748B"/>
                            </Border.Effect>
                            <DockPanel>
                                <!-- Title row -->
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="{}{}" FontSize="16" FontWeight="Bold" Foreground="#4F46E5" Margin="0,0,8,0"/>
                                    <TextBlock Text="JSON Formatter" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PanelTitleFg}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Input label -->
                                <TextBlock DockPanel.Dock="Top" Text="Paste JSON to format:" FontSize="11"
                                           Foreground="{DynamicResource SubLabelFg}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <!-- Input box -->
                                <TextBox DockPanel.Dock="Top" x:Name="FmtInputBox"
                                         AcceptsReturn="True" TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" FontSize="12" Height="180"
                                         Background="{DynamicResource JsonInputBg}" BorderBrush="{DynamicResource JsonInputBorder}" BorderThickness="1"
                                         Padding="10" ContextMenu="{StaticResource TextBoxContextMenu}"/>
                                <!-- Button row -->
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,8,0,8">
                                    <Button Content="⚡ Format" Style="{StaticResource PrimaryButton}"
                                            Click="FormatJsonBtn_Click" Margin="0,0,8,0"/>
                                    <Button Content="🗑 Clear" Style="{StaticResource DangerButton}"
                                            Click="FmtClearBtn_Click"/>
                                </StackPanel>
                                <!-- Output label -->
                                <TextBlock DockPanel.Dock="Top" Text="Formatted output:" FontSize="11"
                                           Foreground="{DynamicResource SubLabelFg}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <!-- Output -->
                                <TextBox x:Name="FmtOutputBox"
                                         IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" FontSize="12"
                                         Background="{DynamicResource JsonOutputGreenBg}" BorderBrush="{DynamicResource JsonOutputGreenBorder}" BorderThickness="1"
                                         Padding="10" ContextMenu="{StaticResource TextBoxContextMenu}"/>
                            </DockPanel>
                        </Border>

                        <!-- RIGHT: JSON Compare -->
                        <Border Grid.Column="2" Background="{DynamicResource CardBg}" CornerRadius="10" Padding="14">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.07" Color="#64748B"/>
                            </Border.Effect>
                            <DockPanel>
                                <!-- Title -->
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="⇄" FontSize="16" FontWeight="Bold" Foreground="#059669" Margin="0,0,8,0"/>
                                    <TextBlock Text="JSON Compare" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PanelTitleFg}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Two input boxes side by side -->
                                <Grid DockPanel.Dock="Top" Height="180" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <DockPanel Grid.Column="0">
                                        <TextBlock DockPanel.Dock="Top" Text="Left JSON" FontSize="11"
                                                   Foreground="{DynamicResource SubLabelFg}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBox x:Name="CmpLeftBox"
                                                 AcceptsReturn="True" TextWrapping="NoWrap"
                                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas" FontSize="12"
                                                 Background="{DynamicResource JsonInputBg}" BorderBrush="{DynamicResource JsonInputBorder}" BorderThickness="1"
                                                 Padding="8" ContextMenu="{StaticResource TextBoxContextMenu}"/>
                                    </DockPanel>
                                    <DockPanel Grid.Column="2">
                                        <TextBlock DockPanel.Dock="Top" Text="Right JSON" FontSize="11"
                                                   Foreground="{DynamicResource SubLabelFg}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBox x:Name="CmpRightBox"
                                                 AcceptsReturn="True" TextWrapping="NoWrap"
                                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas" FontSize="12"
                                                 Background="{DynamicResource JsonInputBg}" BorderBrush="{DynamicResource JsonInputBorder}" BorderThickness="1"
                                                 Padding="8" ContextMenu="{StaticResource TextBoxContextMenu}"/>
                                    </DockPanel>
                                </Grid>
                                <!-- Buttons -->
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="⇄ Compare" Style="{StaticResource SecondaryButton}"
                                            Click="CompareJsonBtn_Click" Margin="0,0,8,0"/>
                                    <Button Content="🗑 Clear" Style="{StaticResource DangerButton}"
                                            Click="CmpClearBtn_Click"/>
                                </StackPanel>
                                <!-- Diff result label -->
                                <TextBlock DockPanel.Dock="Top" Text="Differences:" FontSize="11"
                                           Foreground="{DynamicResource SubLabelFg}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <!-- Diff output -->
                                <TextBox x:Name="CmpResultBox"
                                         IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" FontSize="12"
                                         Background="{DynamicResource JsonOutputYellowBg}" BorderBrush="{DynamicResource JsonOutputYellowBorder}" BorderThickness="1"
                                         Padding="10" ContextMenu="{StaticResource TextBoxContextMenu}"/>
                            </DockPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Crypto Tab -->
                <TabItem Header="🔐 Crypto">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <TextBlock Grid.Row="0" Text="BQE Encrypt / Decrypt  (DES / 3DES · auto-padding)"
                                   FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource KpiValueFg}"
                                   Margin="0,0,0,14"/>

                        <!-- Controls row -->
                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="76"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="76"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Key:" FontWeight="SemiBold"
                                       VerticalAlignment="Center" FontSize="12"/>
                            <ComboBox x:Name="CryptoKeyBox" Grid.Column="2" Height="32"
                                      VerticalContentAlignment="Center" FontFamily="Consolas"
                                      FontSize="11" IsEditable="True"
                                      ToolTip="Select a preset key or type a custom 8-byte key">
                                <ComboBoxItem Content="C#E1b@$0" IsSelected="True"/>
                                <ComboBoxItem Content="E@a2b#$0"/>
                            </ComboBox>

                            <TextBlock Grid.Column="4" Text="Algo:" FontWeight="SemiBold"
                                       VerticalAlignment="Center" FontSize="12"
                                       ToolTip="DES = single DES (56-bit). 3DES = TripleDES with key repeated ×3 (112-bit effective). Auto-fallback tries the other if selected fails."/>
                            <ComboBox x:Name="CryptoAlgoBox" Grid.Column="6" Height="32"
                                      VerticalContentAlignment="Center" FontSize="12"
                                      SelectedIndex="0"
                                      ToolTip="DES = single DES. 3DES = TripleDES (8-byte key expanded ×3). Decrypt auto-falls back if selected fails.">
                                <ComboBoxItem Content="DES"/>
                                <ComboBoxItem Content="3DES"/>
                            </ComboBox>

                            <TextBlock Grid.Column="8" Text="Mode:" FontWeight="SemiBold"
                                       VerticalAlignment="Center" FontSize="12"/>
                            <ComboBox x:Name="CryptoModeBox" Grid.Column="10" Height="32"
                                      VerticalContentAlignment="Center" FontSize="12"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="ECB"/>
                                <ComboBoxItem Content="CBC"/>
                            </ComboBox>

                            <TextBlock Grid.Column="12" Text="Output:" FontWeight="SemiBold"
                                       VerticalAlignment="Center" FontSize="12"/>
                            <ComboBox x:Name="CryptoOutFmtBox" Grid.Column="14" Height="32"
                                      VerticalContentAlignment="Center" FontSize="12"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Hex"/>
                                <ComboBoxItem Content="Base64"/>
                            </ComboBox>
                        </Grid>

                        <!-- Input / Output panels -->
                        <Grid Grid.Row="2" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Input -->
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="120"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Input" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"/>
                                    <TextBlock Text="  (hex, Base64, or plain text)"
                                               FontSize="11" Foreground="{DynamicResource HintFg}" VerticalAlignment="Center"/>
                                    <Button Content="⧉ Paste" Height="22" Padding="8,0"
                                            FontSize="11" Cursor="Hand" Margin="10,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource CopyBtnBorder}"
                                            Background="{DynamicResource CopyBtnBg}" Foreground="{DynamicResource LabelFg}"
                                            Click="CryptoPasteBtn_Click">
                                        <Button.Template><ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/></Trigger></ControlTemplate.Triggers>
                                        </ControlTemplate></Button.Template>
                                    </Button>
                                    <Button Content="✕ Clear" Height="22" Padding="8,0"
                                            FontSize="11" Cursor="Hand" Margin="4,0,0,0"
                                            BorderThickness="1" BorderBrush="#FCA5A5"
                                            Background="#FFF5F5" Foreground="#B91C1C"
                                            Click="CryptoClearBtn_Click">
                                        <Button.Template><ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#FEE2E2"/></Trigger></ControlTemplate.Triggers>
                                        </ControlTemplate></Button.Template>
                                    </Button>
                                </StackPanel>
                                <TextBox x:Name="CryptoInputBox" Grid.Row="1"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         FontFamily="Consolas" FontSize="11"
                                         VerticalScrollBarVisibility="Auto"
                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                         Padding="8,6" Background="{DynamicResource InputBg}"
                                         ToolTip="Paste hex / Base64 cipher to decrypt, or plain text to encrypt"/>
                            </Grid>

                            <!-- Action buttons (middle) -->
                            <StackPanel Grid.Column="1" Orientation="Vertical"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">

                                <!-- Manual DES/3DES -->
                                <TextBlock Text="MANUAL" FontSize="9" FontWeight="Bold"
                                           Foreground="#AEAEB2" HorizontalAlignment="Center"
                                           Margin="0,0,0,5"/>
                                <Button x:Name="DecryptBtn" Content="🔓  Decrypt  →"
                                        Height="34" Padding="12,0" FontSize="12"
                                        FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,6"
                                        BorderThickness="0" Background="#7C3AED" Foreground="White"
                                        Click="DecryptBtn_Click">
                                    <Button.Template><ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#6D28D9"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate></Button.Template>
                                </Button>
                                <Button x:Name="EncryptBtn" Content="🔒  Encrypt  →"
                                        Height="34" Padding="12,0" FontSize="12"
                                        FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,6"
                                        BorderThickness="0" Background="#0D9488" Foreground="White"
                                        Click="EncryptBtn_Click">
                                    <Button.Template><ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#0F766E"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate></Button.Template>
                                </Button>
                                <Button Content="🔄 Try All Keys"
                                        Height="34" Padding="12,0" FontSize="11"
                                        FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,14"
                                        BorderThickness="0" Background="#059669" Foreground="White"
                                        Click="TryAllKeysBtn_Click">
                                    <Button.Template><ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#047857"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate></Button.Template>
                                </Button>

                                <!-- BQE Native -->
                                <Border Height="1" Background="#E5E5EA" Margin="0,0,0,10"/>
                                <TextBlock Text="BQE NATIVE" FontSize="9" FontWeight="Bold"
                                           Foreground="#007AFF" HorizontalAlignment="Center"
                                           Margin="0,0,0,5"
                                           ToolTip="Exact replica of BQECoreSharedLib.Encryption — DES-CBC, ASCII, 5-char length header, Base64"/>
                                <Button Content="🔓  BQE Decrypt"
                                        Height="34" Padding="10,0" FontSize="11"
                                        FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,6"
                                        BorderThickness="0" Background="#007AFF" Foreground="White"
                                        Click="BqeDecryptBtn_Click"
                                        ToolTip="DES-CBC, Key=C#E1b@$0 / IV=E@a2b#$0 (V2), fallback to BQES2011 (V1). Strips 5-char length header.">
                                    <Button.Template><ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#0066DD"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate></Button.Template>
                                </Button>
                                <Button Content="🔒  BQE Encrypt"
                                        Height="34" Padding="10,0" FontSize="11"
                                        FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,6"
                                        BorderThickness="0" Background="#5856D6" Foreground="White"
                                        Click="BqeEncryptBtn_Click"
                                        ToolTip="DES-CBC, Key=C#E1b@$0 / IV=E@a2b#$0 (V2). Prepends 5-char length header. Output: Base64.">
                                    <Button.Template><ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#4845C0"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate></Button.Template>
                                </Button>
                                <Button Content="🔑  BQE Pwd Encrypt"
                                        Height="34" Padding="10,0" FontSize="11"
                                        FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,14"
                                        BorderThickness="0" Background="#FF9500" Foreground="White"
                                        Click="BqePasswordEncryptBtn_Click"
                                        ToolTip="PasswordEncrypt — uses V1 key (BQES2011). Same format as BQE Encrypt but with the legacy key pair.">
                                    <Button.Template><ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#CC7800"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate></Button.Template>
                                </Button>

                                <!-- SHA-256 -->
                                <Border Height="1" Background="#E5E5EA" Margin="0,0,0,10"/>
                                <TextBlock Text="SHA-256" FontSize="9" FontWeight="Bold"
                                           Foreground="#34C759" HorizontalAlignment="Center"
                                           Margin="0,0,0,5"
                                           ToolTip="One-way hash — exact replica of Hashing.ComputeSha256Hash()"/>
                                <Button Content="# Hash (SHA-256)"
                                        Height="34" Padding="10,0" FontSize="11"
                                        FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,6"
                                        BorderThickness="0" Background="#34C759" Foreground="White"
                                        Click="Sha256HashBtn_Click"
                                        ToolTip="Computes SHA-256 of the input text. Matches Hashing.ComputeSha256Hash().">
                                    <Button.Template><ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#28A745"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate></Button.Template>
                                </Button>
                                <Button Content="✔ Verify Hash"
                                        Height="34" Padding="10,0" FontSize="11"
                                        FontWeight="SemiBold" Cursor="Hand"
                                        BorderThickness="0" Background="#636366" Foreground="White"
                                        Click="Sha256VerifyBtn_Click"
                                        ToolTip="Input = plaintext&#10;Output box = the hash to verify against&#10;Checks if SHA-256(input) matches the hash in the output box.">
                                    <Button.Template><ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#48484A"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate></Button.Template>
                                </Button>
                            </StackPanel>

                            <!-- Output -->
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="120"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Output" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"/>
                                    <Button Content="⧉ Copy" Height="22" Padding="8,0"
                                            FontSize="11" Cursor="Hand" Margin="10,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource InfoStripGreenBorder}"
                                            Background="{DynamicResource InfoStripGreenBtnBg}" Foreground="{DynamicResource InfoStripGreenFg}"
                                            Click="CryptoCopyOutputBtn_Click">
                                        <Button.Template><ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource InfoStripGreenBtnHover}"/></Trigger></ControlTemplate.Triggers>
                                        </ControlTemplate></Button.Template>
                                    </Button>
                                    <Button Content="⇄ Swap" Height="22" Padding="8,0"
                                            FontSize="11" Cursor="Hand" Margin="4,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource InfoStripBlueBorder}"
                                            Background="{DynamicResource QuickFetchCcBg}" Foreground="{DynamicResource QuickFetchCcFg}"
                                            Click="CryptoSwapBtn_Click"
                                            ToolTip="Move output back to input">
                                        <Button.Template><ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#E0F2FE"/></Trigger></ControlTemplate.Triggers>
                                        </ControlTemplate></Button.Template>
                                    </Button>
                                </StackPanel>
                                <TextBox x:Name="CryptoOutputBox" Grid.Row="1"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         FontFamily="Consolas" FontSize="11"
                                         IsReadOnly="True"
                                         VerticalScrollBarVisibility="Auto"
                                         BorderBrush="{DynamicResource InfoStripGreenBorder}" BorderThickness="1"
                                         Padding="8,6" Background="{DynamicResource JsonOutputGreenBg}"/>
                            </Grid>
                        </Grid>

                        <!-- Status -->
                        <TextBlock x:Name="CryptoStatusText" Grid.Row="3"
                                   FontSize="11" Foreground="{DynamicResource SubLabelFg}"
                                   TextWrapping="Wrap" Margin="0,4,0,0" Text=""/>
                    </Grid>
                </TabItem>

                <!-- Payrix Portal Tab -->
                <TabItem Header="🌐 Payrix Portal" x:Name="PortalTab"
                         GotFocus="PortalTab_GotFocus">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Toolbar -->
                        <Border Grid.Row="0" Background="{DynamicResource CodeBg}" Padding="10,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔒" FontSize="13"
                                           VerticalAlignment="Center" Margin="0,0,6,0"
                                           Foreground="{DynamicResource SubText}"/>
                                <TextBox x:Name="PortalAddressBar" Grid.Column="1"
                                         FontFamily="Consolas" FontSize="12"
                                         Background="{DynamicResource InputBg}" Foreground="{DynamicResource InputFg}"
                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                         Padding="8,4" Height="30" VerticalContentAlignment="Center"
                                         KeyDown="PortalAddressBar_KeyDown"/>
                                <Button Grid.Column="2" Content="Go" Style="{StaticResource PrimaryButton}"
                                        Padding="14,4" FontSize="12" Click="PortalGoBtn_Click"/>
                                <Button Grid.Column="4" Content="⟳ Reload" Style="{StaticResource PrimaryButton}"
                                        Padding="10,4" FontSize="12" Background="#475569"
                                        Click="PortalReloadBtn_Click"/>
                                <Button Grid.Column="6" Content="🔑 Login" Style="{StaticResource PrimaryButton}"
                                        Padding="10,4" FontSize="12" Background="#7C3AED"
                                        Click="PortalLoginBtn_Click"
                                        ToolTip="Auto-login to Payrix portal"/>
                            </Grid>
                        </Border>

                        <!-- Embedded browser -->
                        <wv2:WebView2 x:Name="PortalBrowser" Grid.Row="1"
                                      NavigationCompleted="PortalBrowser_NavigationCompleted"/>
                    </Grid>
                </TabItem>

                <!-- ═══════════════════════════════════════════════════════
                     TAB 8 — SETTINGS
                     ═══════════════════════════════════════════════════════ -->
                <TabItem Header="⚙ Settings">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20,24,24">
                        <StackPanel MaxWidth="680" HorizontalAlignment="Left">

                            <!-- Page header -->
                            <StackPanel Margin="0,0,0,28">
                                <TextBlock Text="⚙  Settings" FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock Text="Configure appearance, environment, and preferences."
                                           FontSize="12.5" Foreground="{DynamicResource SubText}" Margin="0,5,0,0"/>
                            </StackPanel>

                            <!-- ── Appearance ───────────────────────────────────── -->
                            <TextBlock Text="Appearance" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,12"/>
                            <Border Background="{DynamicResource CardBg}" CornerRadius="14"
                                    Padding="22,18" Margin="0,0,0,24"
                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Theme" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,6"/>
                                    <TextBlock Text="Switch between light and dark mode for the entire application."
                                               FontSize="12" Foreground="{DynamicResource SubText}" Margin="0,0,0,16"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                        <Button x:Name="SettingsLightBtn" Content="☀  Light Mode"
                                                Style="{StaticResource PrimaryButton}"
                                                Background="#374151" Margin="0,0,10,0"
                                                Click="SettingsLightTheme_Click"
                                                ToolTip="Switch to light theme"/>
                                        <Button x:Name="SettingsDarkBtn" Content="🌙  Dark Mode"
                                                Style="{StaticResource PrimaryButton}"
                                                Background="#4F46E5"
                                                Click="SettingsDarkTheme_Click"
                                                ToolTip="Switch to dark theme (current default)"/>
                                        <!-- Active badge -->
                                        <Border x:Name="ThemeActiveBadge" Background="#4F46E520"
                                                BorderBrush="#4F46E5" BorderThickness="1"
                                                CornerRadius="6" Padding="10,6" Margin="14,0,0,0"
                                                VerticalAlignment="Center">
                                            <TextBlock x:Name="ThemeActiveBadgeText" Text="● Dark Mode Active"
                                                       FontSize="11" FontWeight="SemiBold" Foreground="#A5B4FC"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ── API Environment ──────────────────────────────── -->
                            <TextBlock Text="API Environment" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,12"/>
                            <Border Background="{DynamicResource CardBg}" CornerRadius="14"
                                    Padding="22,18" Margin="0,0,0,24"
                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Active environment is controlled via the Sandbox / Production toggle in the header toolbar."
                                               FontSize="12.5" Foreground="{DynamicResource SubText}" TextWrapping="Wrap"/>
                                    <Border Margin="0,14,0,0" Background="{DynamicResource DbConfigBg}"
                                            CornerRadius="8" Padding="14,10"
                                            BorderBrush="{DynamicResource DbConfigBorder}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="🟢" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock FontSize="12" Foreground="{DynamicResource PrimaryText}">
                                                    <Run FontWeight="SemiBold">Sandbox:</Run>
                                                    <Run Foreground="{DynamicResource SubText}">test.api.payrix.com</Run>
                                                </TextBlock>
                                                <TextBlock FontSize="12" Foreground="{DynamicResource PrimaryText}" Margin="0,4,0,0">
                                                    <Run FontWeight="SemiBold">Production:</Run>
                                                    <Run Foreground="{DynamicResource SubText}">api.payrix.com</Run>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- ── About ─────────────────────────────────────────── -->
                            <TextBlock Text="About" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,12"/>
                            <Border Background="{DynamicResource CardBg}" CornerRadius="14"
                                    Padding="22,18" Margin="0,0,0,0"
                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,14,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#7C3AED" Offset="0"/>
                                                    <GradientStop Color="#4F46E5" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="⚡" FontSize="18" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" Foreground="White"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="BQE Core ePayment Tools" FontSize="16" FontWeight="Bold"
                                                           Foreground="#A5B4FC"/>
                                                <TextBlock Text="  v2.0" FontSize="12"
                                                           Foreground="{DynamicResource MutedText}"
                                                           VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                            </StackPanel>
                                            <TextBlock Text="BQE Software — Internal QA &amp; Debug Tool"
                                                       FontSize="11.5" Foreground="{DynamicResource SubText}"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,4,0,14"/>
                                    <TextBlock FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap">
                                        Internal tool for searching Payrix transactions, testing webhooks,
                                        inspecting raw API responses, and managing crypto/encoding utilities
                                        for BQE Core payment debugging.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══════════════════════════════════════════════════════
                     TAB 9 — HELP & DOCS
                     ═══════════════════════════════════════════════════════ -->
                <TabItem Header="❓ Help &amp; Docs">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20,24,24">
                        <StackPanel>
                            <!-- Page header -->
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="❓  Help &amp; Documentation" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock Text="Complete reference for BQE Core APIs, HTTP Client, performance testing, and Payrix webhook flows." FontSize="12.5" Foreground="{DynamicResource SubText}" Margin="0,5,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- ══ Quick-nav chips ══ -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20" FlowDirection="LeftToRight">
                                <Border CornerRadius="20" Background="{DynamicResource TabHoverBg}" Padding="12,5" Margin="0,0,6,0">
                                    <TextBlock Text="🔌 BQE Core API" FontSize="11" Foreground="{DynamicResource SubText}"/>
                                </Border>
                                <Border CornerRadius="20" Background="{DynamicResource TabHoverBg}" Padding="12,5" Margin="0,0,6,0">
                                    <TextBlock Text="📦 BQEParameters" FontSize="11" Foreground="{DynamicResource SubText}"/>
                                </Border>
                                <Border CornerRadius="20" Background="{DynamicResource TabHoverBg}" Padding="12,5" Margin="0,0,6,0">
                                    <TextBlock Text="🌍 Environments" FontSize="11" Foreground="{DynamicResource SubText}"/>
                                </Border>
                                <Border CornerRadius="20" Background="{DynamicResource TabHoverBg}" Padding="12,5" Margin="0,0,6,0">
                                    <TextBlock Text="📡 HTTP Client" FontSize="11" Foreground="{DynamicResource SubText}"/>
                                </Border>
                                <Border CornerRadius="20" Background="{DynamicResource TabHoverBg}" Padding="12,5">
                                    <TextBlock Text="⚡ Performance" FontSize="11" Foreground="{DynamicResource SubText}"/>
                                </Border>
                            </StackPanel>

                            <!-- ══════════════════════════════════════════════════
                                 SECTION A — BQE Core API Reference
                                 ══════════════════════════════════════════════════ -->
                            <TextBlock Text="🔌  BQE Core API Reference" FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,10"/>

                            <!-- A1: Authentication -->
                            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="22,18" Margin="0,0,0,12" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,12,0">
                                            <Border.Background><SolidColorBrush Color="#F59E0B" Opacity="0.2"/></Border.Background>
                                            <TextBlock Text="🔑" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Authentication" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,0,0,12"/>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Header name" FontWeight="SemiBold" Foreground="#F59E0B" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="Authorization: Bearer {token}" FontSize="12" Foreground="{DynamicResource SubText}" FontFamily="Cascadia Code, Consolas, Courier New"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
