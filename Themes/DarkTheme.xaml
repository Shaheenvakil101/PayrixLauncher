    <SolidColorBrush x:Key="InfoBoxBg"             Color="#1E2A3D"/>
    <SolidColorBrush x:Key="CopyBtnBg"             Color="#1E2A3D"/>
    <SolidColorBrush x:Key="CopyBtnBorder"         Color="#2A3A52"/>

    <!-- ── Quick-fetch chips ─────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="QuickFetchAchBg"       Color="#1A1E35"/>
    <SolidColorBrush x:Key="QuickFetchAchBorder"   Color="#2E3660"/>
    <SolidColorBrush x:Key="QuickFetchAchFg"       Color="#7B8CDE"/>
    <SolidColorBrush x:Key="QuickFetchCcBg"        Color="#12213A"/>
    <SolidColorBrush x:Key="QuickFetchCcBorder"    Color="#1A3A6A"/>
    <SolidColorBrush x:Key="QuickFetchCcFg"        Color="#1E88E5"/>

    <!-- ── Cards / tiles ─────────────────────────────────────────────────── -->
