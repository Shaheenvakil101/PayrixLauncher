    <SolidColorBrush x:Key="TabSelectedFg"      Color="#1E88E5"/>
    <SolidColorBrush x:Key="TabSelectedBorder"  Color="#1E88E5"/>
    <SolidColorBrush x:Key="TabControlBg"       Color="#111827"/>
