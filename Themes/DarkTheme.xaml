    <SolidColorBrush x:Key="JsonInputBorder"          Color="#2A3A52"/>
    <SolidColorBrush x:Key="JsonOutputGreenBg"        Color="#0D2518"/>
    <SolidColorBrush x:Key="JsonOutputGreenBorder"    Color="#22C55E"/>
    <SolidColorBrush x:Key="JsonOutputYellowBg"       Color="#251D0A"/>
    <SolidColorBrush x:Key="JsonOutputYellowBorder"   Color="#F59E0B"/>

    <!-- ── Labels ────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="LabelFg"            Color="#E2E8F0"/>
    <SolidColorBrush x:Key="SubLabelFg"         Color="#8D9BB5"/>
    <SolidColorBrush x:Key="HintFg"             Color="#4B5A72"/>

    <!-- ── Info banner ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="InfoBannerBg"       Color="#12213A"/>
    <SolidColorBrush x:Key="InfoBannerBorder"   Color="#1E88E5"/>
    <SolidColorBrush x:Key="InfoBannerTitleFg"  Color="#64B5F6"/>
    <SolidColorBrush x:Key="InfoBannerNumFg"    Color="#90CAF9"/>
    <SolidColorBrush x:Key="InfoBannerTextFg"   Color="#CBD5E1"/>

    <!-- ── Search card ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="SearchCardBg"       Color="#1E2A3D"/>
    <SolidColorBrush x:Key="SearchCardBorder"   Color="#2A3A52"/>

    <!-- ── Logo — BQE Core dark blue gradient ───────────────────────────── -->
