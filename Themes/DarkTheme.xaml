        <GradientStop Color="#296598" Offset="0"/>
        <GradientStop Color="#4d94cf" Offset="1"/>
    </LinearGradientBrush>

    <!-- ── Section headers ───────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="EmailSectionBg"     Color="#1A1E35"/>
    <SolidColorBrush x:Key="EmailSectionBorder" Color="#2E3660"/>
    <SolidColorBrush x:Key="EmailSectionFg"     Color="#7B8CDE"/>

    <SolidColorBrush x:Key="TxnSectionBg"       Color="#12213A"/>
    <SolidColorBrush x:Key="TxnSectionBorder"   Color="#1A3A6A"/>
    <SolidColorBrush x:Key="TxnSectionFg"       Color="#1E88E5"/>

    <SolidColorBrush x:Key="DisbSectionBg"      Color="#0D2518"/>
    <SolidColorBrush x:Key="DisbSectionBorder"  Color="#1A4A28"/>
    <SolidColorBrush x:Key="DisbSectionFg"      Color="#22C55E"/>

    <!-- ── Webhook panel ─────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="WebhookPanelBg"       Color="#0D2518"/>
    <SolidColorBrush x:Key="WebhookPanelBorder"   Color="#22C55E"/>
    <SolidColorBrush x:Key="WebhookConfigBg"      Color="#1E2A3D"/>
    <SolidColorBrush x:Key="WebhookConfigBorder"  Color="#22C55E"/>
    <SolidColorBrush x:Key="WebhookConfigFg"      Color="#22C55E"/>

    <!-- ── Info strips ───────────────────────────────────────────────────── -->
