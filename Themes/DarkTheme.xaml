<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════
         DYNAMIC ISLAND — Payrix Tools
         Pure-black canvas · pill controls · vivid blue accent · iOS 17+ DNA
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- ── Window background ─────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="WindowBg"           Color="#000000"/>

    <!-- ── Sidebar ───────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="SidebarBg"          Color="#0A0A0A"/>
    <SolidColorBrush x:Key="SidebarBorder"      Color="#1C1C1C"/>
    <SolidColorBrush x:Key="SidebarNavFg"       Color="#6E6E73"/>

    <!-- ── Card surfaces ─────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="CardBg"             Color="#111111"/>
    <SolidColorBrush x:Key="CardBorder"         Color="#1E1E1E"/>
    <Color            x:Key="CardShadowColor"   >#000000</Color>

    <!-- ── Core text ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="PrimaryText"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SubText"            Color="#8C8C8C"/>
    <SolidColorBrush x:Key="MutedText"          Color="#484848"/>

    <!-- ── DataGrid ──────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="GridRowBg"          Color="#000000"/>
    <SolidColorBrush x:Key="GridAltRowBg"       Color="#0C0C0C"/>
    <SolidColorBrush x:Key="GridHeaderBg"       Color="#000000"/>
    <SolidColorBrush x:Key="GridHeaderFg"       Color="#6E6E73"/>
    <SolidColorBrush x:Key="GridBorder"         Color="#1C1C1C"/>
    <SolidColorBrush x:Key="GridFg"             Color="#FFFFFF"/>

    <!-- ── Inputs ────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="InputBg"            Color="#1A1A1A"/>
    <SolidColorBrush x:Key="InputBorder"        Color="#2C2C2C"/>
    <SolidColorBrush x:Key="InputFg"            Color="#FFFFFF"/>

    <!-- ── Tabs ──────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TabFg"              Color="#555555"/>
    <SolidColorBrush x:Key="TabSelectedFg"      Color="#0A84FF"/>
    <SolidColorBrush x:Key="TabSelectedBorder"  Color="#0A84FF"/>
    <SolidColorBrush x:Key="TabControlBg"       Color="#000000"/>
    <SolidColorBrush x:Key="TabHoverBg"         Color="#161616"/>

    <!-- ── Code / JSON ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="CodeBg"             Color="#000000"/>
    <SolidColorBrush x:Key="CodeFg"             Color="#E5E5E5"/>

    <!-- ── KPI ───────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="StatCountFg"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="KpiHeaderBg"        Color="#000000"/>
    <SolidColorBrush x:Key="KpiHeaderFg"        Color="#8C8C8C"/>
    <SolidColorBrush x:Key="KpiValueFg"         Color="#0A84FF"/>
    <SolidColorBrush x:Key="KpiCardBorder"      Color="#1E1E1E"/>

    <!-- ── Semantic ──────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="SeparatorFg"           Color="#1C1C1C"/>
    <SolidColorBrush x:Key="StatusLabelFg"         Color="#8C8C8C"/>
    <SolidColorBrush x:Key="InfoBoxBg"             Color="#111111"/>
    <SolidColorBrush x:Key="CopyBtnBg"             Color="#1A1A1A"/>
    <SolidColorBrush x:Key="CopyBtnBorder"         Color="#2C2C2C"/>

    <!-- ── Quick-fetch chips ─────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="QuickFetchAchBg"       Color="#0A0A18"/>
    <SolidColorBrush x:Key="QuickFetchAchBorder"   Color="#2C2C48"/>
    <SolidColorBrush x:Key="QuickFetchAchFg"       Color="#7B7BF7"/>
    <SolidColorBrush x:Key="QuickFetchCcBg"        Color="#00101F"/>
    <SolidColorBrush x:Key="QuickFetchCcBorder"    Color="#003060"/>
    <SolidColorBrush x:Key="QuickFetchCcFg"        Color="#0A84FF"/>

    <!-- ── Cards / tiles ─────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="CardBorder2"        Color="#1E1E1E"/>
    <SolidColorBrush x:Key="TileCardBg"         Color="#111111"/>
    <SolidColorBrush x:Key="PanelTitleFg"       Color="#FFFFFF"/>

    <!-- ── JSON formatter ────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="JsonInputBg"              Color="#111111"/>
    <SolidColorBrush x:Key="JsonInputBorder"          Color="#2C2C2C"/>
    <SolidColorBrush x:Key="JsonOutputGreenBg"        Color="#001A0A"/>
    <SolidColorBrush x:Key="JsonOutputGreenBorder"    Color="#30D158"/>
    <SolidColorBrush x:Key="JsonOutputYellowBg"       Color="#1A0F00"/>
    <SolidColorBrush x:Key="JsonOutputYellowBorder"   Color="#FF9F0A"/>

    <!-- ── Labels ────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="LabelFg"            Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SubLabelFg"         Color="#8C8C8C"/>
    <SolidColorBrush x:Key="HintFg"             Color="#484848"/>

    <!-- ── Info banner (lineItemDetailIndicator / inline help banners) ──── -->
    <SolidColorBrush x:Key="InfoBannerBg"       Color="#1E2A3A"/>
    <SolidColorBrush x:Key="InfoBannerBorder"   Color="#2563EB"/>
    <SolidColorBrush x:Key="InfoBannerTitleFg"  Color="#60A5FA"/>
    <SolidColorBrush x:Key="InfoBannerNumFg"    Color="#93C5FD"/>
    <SolidColorBrush x:Key="InfoBannerTextFg"   Color="#CBD5E1"/>

    <!-- ── Search card ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="SearchCardBg"       Color="#111111"/>
    <SolidColorBrush x:Key="SearchCardBorder"   Color="#1E1E1E"/>

    <!-- ── Logo — Dynamic Island gradient ──────────────────────────────────── -->
    <LinearGradientBrush x:Key="LogoBadgeBg" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0A84FF" Offset="0"/>
        <GradientStop Color="#5E5CE6" Offset="1"/>
    </LinearGradientBrush>

    <!-- ── Section headers ───────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="EmailSectionBg"     Color="#0A0A18"/>
    <SolidColorBrush x:Key="EmailSectionBorder" Color="#2C2C48"/>
    <SolidColorBrush x:Key="EmailSectionFg"     Color="#7B7BF7"/>

    <SolidColorBrush x:Key="TxnSectionBg"       Color="#00101F"/>
    <SolidColorBrush x:Key="TxnSectionBorder"   Color="#003060"/>
    <SolidColorBrush x:Key="TxnSectionFg"       Color="#0A84FF"/>

    <SolidColorBrush x:Key="DisbSectionBg"      Color="#001A0A"/>
    <SolidColorBrush x:Key="DisbSectionBorder"  Color="#003820"/>
    <SolidColorBrush x:Key="DisbSectionFg"      Color="#30D158"/>

    <!-- ── Webhook panel ─────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="WebhookPanelBg"       Color="#001A0A"/>
    <SolidColorBrush x:Key="WebhookPanelBorder"   Color="#30D158"/>
    <SolidColorBrush x:Key="WebhookConfigBg"      Color="#111111"/>
    <SolidColorBrush x:Key="WebhookConfigBorder"  Color="#30D158"/>
    <SolidColorBrush x:Key="WebhookConfigFg"      Color="#30D158"/>

    <!-- ── Info strips ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="InfoStripGreenBorder"     Color="#30D158"/>
    <SolidColorBrush x:Key="InfoStripBlueBorder"      Color="#0A84FF"/>
    <SolidColorBrush x:Key="InfoStripGreenFg"         Color="#30D158"/>
    <SolidColorBrush x:Key="InfoStripBlueFg"          Color="#0A84FF"/>
    <SolidColorBrush x:Key="InfoStripGreenBtnBg"      Color="#001A0A"/>
    <SolidColorBrush x:Key="InfoStripGreenBtnHover"   Color="#003018"/>
    <SolidColorBrush x:Key="InfoStripBlueBtnBg"       Color="#001428"/>
    <SolidColorBrush x:Key="InfoStripBlueBtnHover"    Color="#002040"/>
    <SolidColorBrush x:Key="InfoStripBlueBtnBg2"      Color="#001428"/>

    <!-- ── Orange / amber ────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="OrangePanelBg"       Color="#1A0A00"/>
    <SolidColorBrush x:Key="OrangePanelBorder"   Color="#FF9F0A"/>
    <SolidColorBrush x:Key="OrangePanelFg"       Color="#FF9F0A"/>

    <!-- ── DB config ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="DbConfigBg"          Color="#111111"/>
    <SolidColorBrush x:Key="DbConfigBlueBg"      Color="#001428"/>
    <SolidColorBrush x:Key="DbConfigBorder"      Color="#1E1E1E"/>
    <SolidColorBrush x:Key="DbConfigBlueBorder"  Color="#0A84FF"/>

    <!-- ── Summary bar ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="SummaryBarBg"        Color="#0A0A0A"/>
    <SolidColorBrush x:Key="SummaryBarBorder"    Color="#1C1C1C"/>

    <!-- ── Webhook test row states ───────────────────────────────────────── -->
    <SolidColorBrush x:Key="TestRowPassBg"       Color="#001A0A"/>
    <SolidColorBrush x:Key="TestRowFailBg"       Color="#1A0000"/>
    <SolidColorBrush x:Key="TestRowRunningBg"    Color="#1A0F00"/>

    <!-- ── Surface / convenience ─────────────────────────────────────────── -->
    <SolidColorBrush x:Key="DarkSurface"         Color="#111111"/>
    <SolidColorBrush x:Key="DarkSurface2"        Color="#1A1A1A"/>
    <SolidColorBrush x:Key="DarkBorder"          Color="#1E1E1E"/>
    <SolidColorBrush x:Key="DarkText"            Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DarkSubText"         Color="#8C8C8C"/>
    <SolidColorBrush x:Key="DarkAccent"          Color="#0A84FF"/>
    <SolidColorBrush x:Key="DarkBtnBg"           Color="#1A1A1A"/>
    <SolidColorBrush x:Key="DarkBtnBgHover"      Color="#242424"/>
    <SolidColorBrush x:Key="DarkScrollBg"        Color="#000000"/>

    <!-- ── Env toggle (inactive) ─────────────────────────────────────────── -->
    <SolidColorBrush x:Key="EnvBtnInactiveBg"     Color="#1A1A1A"/>
    <SolidColorBrush x:Key="EnvBtnInactiveBorder" Color="#2C2C2C"/>
    <SolidColorBrush x:Key="EnvBtnInactiveFg"     Color="#8C8C8C"/>

    <!-- ── FgDefault (generic text fallback) ─────────────────────────────── -->
    <SolidColorBrush x:Key="FgDefault"           Color="#FFFFFF"/>


    <!-- ═══════════════════════════════════════════════════════════════════
         SCROLLBAR — 4px pill, whisper-thin, auto-hide feel
         ═══════════════════════════════════════════════════════════════════ -->

    <Style x:Key="DarkScrollThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop"             Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="Bd" Background="#333333" CornerRadius="2"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#555555"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#0A84FF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DarkScrollPageBtn" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop"             Value="False"/>
        <Setter Property="Focusable"             Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="DarkVScrollBar" TargetType="ScrollBar">
        <Border Background="Transparent" Width="5" Padding="1.5,4">
            <Track x:Name="PART_Track" IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource DarkScrollPageBtn}" Command="ScrollBar.PageUpCommand"/>
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource DarkScrollThumb}" Margin="0,2"/>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource DarkScrollPageBtn}" Command="ScrollBar.PageDownCommand"/>
                </Track.IncreaseRepeatButton>
            </Track>
        </Border>
    </ControlTemplate>

    <ControlTemplate x:Key="DarkHScrollBar" TargetType="ScrollBar">
        <Border Background="Transparent" Height="5" Padding="4,1.5">
            <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource DarkScrollPageBtn}" Command="ScrollBar.PageLeftCommand"/>
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource DarkScrollThumb}" Margin="2,0"/>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource DarkScrollPageBtn}" Command="ScrollBar.PageRightCommand"/>
                </Track.IncreaseRepeatButton>
            </Track>
        </Border>
    </ControlTemplate>

    <Style TargetType="ScrollBar">
        <Setter Property="OverridesDefaultStyle"  Value="True"/>
        <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Width"    Value="5"/>
                <Setter Property="Template" Value="{StaticResource DarkVScrollBar}"/>
            </Trigger>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height"   Value="5"/>
                <Setter Property="Template" Value="{StaticResource DarkHScrollBar}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="CanContentScroll"            Value="False"/>
        <Setter Property="PanningMode"                 Value="VerticalOnly"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ScrollContentPresenter Grid.Column="0" Grid.Row="0"
                                                CanContentScroll="{TemplateBinding CanContentScroll}"/>
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Grid.Column="1" Grid.Row="0" Orientation="Vertical"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                   Grid.Column="0" Grid.Row="1" Orientation="Horizontal"
                                   Value="{TemplateBinding HorizontalOffset}"
                                   Maximum="{TemplateBinding ScrollableWidth}"
                                   ViewportSize="{TemplateBinding ViewportWidth}"
                                   Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ═══════════════════════════════════════════════════════════════════
         CONTROL STYLES — Dynamic Island
         Black canvas · pill shapes · 0A84FF accent · high contrast
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- Window -->
    <Style TargetType="Window">
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI Variable Text, SF Pro Display, Segoe UI, Inter"/>
        <Setter Property="FontSize"   Value="13"/>
    </Style>

    <!-- TextBlock -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground"                     Value="#FFFFFF"/>
        <Setter Property="FontFamily"                     Value="Segoe UI Variable Display, Segoe UI Variable Text, SF Pro Display, Segoe UI, Inter"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode"  Value="ClearType"/>
    </Style>

    <!-- TextBox — pill, no visible border at rest, glows blue on focus -->
    <Style TargetType="TextBox">
        <Setter Property="Background"      Value="#1A1A1A"/>
        <Setter Property="Foreground"      Value="#FFFFFF"/>
        <Setter Property="BorderBrush"     Value="#2C2C2C"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CaretBrush"      Value="#0A84FF"/>
        <Setter Property="SelectionBrush"  Value="#0A84FF"/>
        <Setter Property="FontFamily"      Value="Segoe UI Variable Display, Segoe UI Variable Text, SF Pro Display, Segoe UI, Inter"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Padding="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      CanContentScroll="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#0A84FF"/>
                            <Setter TargetName="Bd" Property="BorderThickness" Value="1.5"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#444444"/>
                        </Trigger>
                        <Trigger Property="IsReadOnly" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#111111"/>
                            <Setter Property="Foreground"                 Value="#6E6E73"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- PasswordBox -->
    <Style TargetType="PasswordBox">
        <Setter Property="Background"      Value="#1A1A1A"/>
        <Setter Property="Foreground"      Value="#FFFFFF"/>
        <Setter Property="BorderBrush"     Value="#2C2C2C"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CaretBrush"      Value="#0A84FF"/>
        <Setter Property="SelectionBrush"  Value="#0A84FF"/>
        <Setter Property="FontFamily"      Value="Segoe UI Variable Display, Segoe UI Variable Text, SF Pro Display, Segoe UI, Inter"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Padding="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#0A84FF"/>
                            <Setter TargetName="Bd" Property="BorderThickness" Value="1.5"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#444444"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox -->
    <Style TargetType="ComboBox">
        <Setter Property="Background"  Value="#1A1A1A"/>
        <Setter Property="Foreground"  Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#2C2C2C"/>
        <Setter Property="FontFamily"  Value="Segoe UI Variable Display, Segoe UI Variable Text, SF Pro Display, Segoe UI, Inter"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="1"
                                      Focusable="False"
                                      IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay,
                                                  RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="TBd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="24"/>
                                            </Grid.ColumnDefinitions>
                                            <Path Grid.Column="1" HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Data="M0,0 L4,5 L8,0 Z"
                                                  Fill="#555555"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TBd" Property="BorderBrush" Value="#444444"/>
                                            <Setter TargetName="TBd" Property="Background"  Value="#242424"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="TBd" Property="BorderBrush" Value="#0A84FF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter x:Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          Margin="11,0,28,0"
                                          VerticalAlignment="Center"/>
                        <TextBox x:Name="PART_EditableTextBox"
                                 Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}"
                                 Margin="8,0,28,0" VerticalAlignment="Center"
                                 Background="Transparent" Foreground="#FFFFFF"
                                 BorderThickness="0"/>
                        <Popup x:Name="Popup" Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True" Focusable="False"
                               PopupAnimation="Fade">
                            <Grid x:Name="DropDown"
                                  MinWidth="{TemplateBinding ActualWidth}"
                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border Background="#161616" BorderBrush="#2C2C2C"
                                        BorderThickness="1" CornerRadius="14" Padding="4">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="28" ShadowDepth="6"
                                                          Opacity="0.80" Color="#000000"/>
                                    </Border.Effect>
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="ContentSite"          Property="Visibility" Value="Hidden"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBoxItem -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="Padding"    Value="11,7"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI Variable Text, SF Pro Display, Segoe UI, Inter"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#001428"/>
                            <Setter Property="Foreground"                 Value="#0A84FF"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#001428"/>
                            <Setter Property="Foreground"                 Value="#0A84FF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TabControl -->
    <Style TargetType="TabControl">
        <Setter Property="Background"      Value="#000000"/>
        <Setter Property="BorderBrush"     Value="#1C1C1C"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- TabItem — floating pill on hover, blue underline when selected -->
    <Style TargetType="TabItem">
        <Setter Property="Background"  Value="Transparent"/>
        <Setter Property="Foreground"  Value="#555555"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Padding"     Value="18,10"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="FontFamily"  Value="Segoe UI Variable Display, Segoe UI Variable Text, SF Pro Display, Segoe UI, Inter"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="TabBorder" Background="Transparent"
                            BorderThickness="0,0,0,2" BorderBrush="Transparent"
                            CornerRadius="10,10,0,0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter ContentSource="Header"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                          TextBlock.FontWeight="Medium"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="#0A84FF"/>
                            <Setter Property="Foreground" Value="#0A84FF"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter TargetName="TabBorder" Property="Background" Value="#161616"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Button — pill shape, black tinted surface, crisp white label -->
    <Style TargetType="Button">
        <Setter Property="Background"      Value="#1A1A1A"/>
        <Setter Property="Foreground"      Value="#FFFFFF"/>
        <Setter Property="BorderBrush"     Value="#2C2C2C"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="FontFamily"      Value="Segoe UI Variable Display, Segoe UI Variable Text, SF Pro Display, Segoe UI, Inter"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="22" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"  Value="#242424"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#3A3A3A"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"  Value="#0A0A0A"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#0A84FF"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.30"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CheckBox -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI Variable Text, SF Pro Display, Segoe UI, Inter"/>
    </Style>

    <!-- RadioButton -->
    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI Variable Text, SF Pro Display, Segoe UI, Inter"/>
    </Style>

    <!-- DatePicker -->
    <Style TargetType="DatePicker">
        <Setter Property="Background"  Value="#1A1A1A"/>
        <Setter Property="Foreground"  Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#2C2C2C"/>
        <Setter Property="FontFamily"  Value="Segoe UI Variable Display, Segoe UI Variable Text, SF Pro Display, Segoe UI, Inter"/>
    </Style>

    <!-- DataGrid — floating rows on pure-black canvas -->
    <Style TargetType="DataGrid">
        <Setter Property="Background"               Value="#000000"/>
        <Setter Property="Foreground"               Value="#FFFFFF"/>
        <Setter Property="BorderBrush"              Value="#1C1C1C"/>
        <Setter Property="BorderThickness"          Value="0"/>
        <Setter Property="RowBackground"            Value="#000000"/>
        <Setter Property="AlternatingRowBackground" Value="#0C0C0C"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#1A1A1A"/>
        <Setter Property="VerticalGridLinesBrush"   Value="Transparent"/>
        <Setter Property="ColumnHeaderHeight"       Value="38"/>
        <Setter Property="RowHeight"                Value="40"/>
        <Setter Property="FontFamily"               Value="Segoe UI Variable Display, Segoe UI Variable Text, SF Pro Display, Segoe UI, Inter"/>
        <Setter Property="FontSize"                 Value="12.5"/>
        <Setter Property="SelectionUnit"            Value="FullRow"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background"      Value="#000000"/>
        <Setter Property="Foreground"      Value="#555555"/>
        <Setter Property="BorderBrush"     Value="#1A1A1A"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding"         Value="12,0"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="FontSize"        Value="11"/>
        <Setter Property="FontFamily"      Value="Segoe UI Variable Display, Segoe UI Variable Text, SF Pro Display, Segoe UI, Inter"/>
        <Setter Property="Height"          Value="38"/>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Foreground"      Value="#FFFFFF"/>
        <Setter Property="BorderBrush"     Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="4,0"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#001428"/>
                <Setter Property="Foreground" Value="#0A84FF"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Background"      Value="#000000"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin"          Value="0"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#001428"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#161616"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Label -->
    <Style TargetType="Label">
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI Variable Text, SF Pro Display, Segoe UI, Inter"/>
    </Style>

    <!-- GroupBox -->
    <Style TargetType="GroupBox">
        <Setter Property="Foreground"  Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#1E1E1E"/>
        <Setter Property="FontFamily"  Value="Segoe UI Variable Display, Segoe UI Variable Text, SF Pro Display, Segoe UI, Inter"/>
    </Style>

    <!-- ToolTip — floating pill, deep shadow -->
    <Style TargetType="ToolTip">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="0"/>
        <Setter Property="HasDropShadow"   Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="#161616" CornerRadius="14"
                            Padding="14,9" BorderBrush="#2C2C2C" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="32" ShadowDepth="6"
                                              Opacity="0.90" Color="#000000"/>
                        </Border.Effect>
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="#FFFFFF" FontSize="12"
                                   FontFamily="Segoe UI Variable Display, Segoe UI Variable Text, SF Pro Display, Segoe UI, Inter"
                                   TextWrapping="Wrap" MaxWidth="440"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ContextMenu — floating pill menu -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background"  Value="#161616"/>
        <Setter Property="Foreground"  Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#2C2C2C"/>
        <Setter Property="FontFamily"  Value="Segoe UI Variable Display, Segoe UI Variable Text, SF Pro Display, Segoe UI, Inter"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="#161616" BorderBrush="#2C2C2C"
                            BorderThickness="1" CornerRadius="16" Padding="4">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="32" ShadowDepth="6"
                                              Opacity="0.90" Color="#000000"/>
                        </Border.Effect>
                        <ItemsPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI Variable Text, SF Pro Display, Segoe UI, Inter"/>
        <Setter Property="Padding"    Value="13,8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}" Margin="0,1">
                        <ContentPresenter ContentSource="Header"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#001428"/>
                            <Setter Property="Foreground"                 Value="#0A84FF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Height="1" Background="#1E1E1E" Margin="8,3"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
