    <SolidColorBrush x:Key="InfoStripBlueBorder"      Color="#1E88E5"/>
    <SolidColorBrush x:Key="InfoStripGreenFg"         Color="#22C55E"/>
    <SolidColorBrush x:Key="InfoStripBlueFg"          Color="#1E88E5"/>
