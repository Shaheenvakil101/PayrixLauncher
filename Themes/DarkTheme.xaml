    <SolidColorBrush x:Key="KpiHeaderBg"        Color="#1B2030"/>
    <SolidColorBrush x:Key="KpiHeaderFg"        Color="#8D9BB5"/>
    <SolidColorBrush x:Key="KpiValueFg"         Color="#1E88E5"/>
    <SolidColorBrush x:Key="KpiCardBorder"      Color="#2A3A52"/>

    <!-- ── Semantic ──────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="SeparatorFg"           Color="#2A3A52"/>
