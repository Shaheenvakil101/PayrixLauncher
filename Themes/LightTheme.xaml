<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════
         WINDOWS 11 FLUENT DESIGN — LIGHT THEME
         Mica #F3F3F3 · Cards #FFFFFF · Accent #0078D4
         Font: Segoe UI Variable · Radius: 4px controls / 8px cards
         ═══════════════════════════════════════════════════════════════════ -->

    <SolidColorBrush x:Key="WindowBg"           Color="#F3F3F3"/>

    <!-- ── Sidebar (NavigationView pane — slightly tinted Mica) ──────────── -->
    <SolidColorBrush x:Key="SidebarBg"          Color="#EBEBEB"/>
    <SolidColorBrush x:Key="SidebarBorder"      Color="#E0E0E0"/>
    <SolidColorBrush x:Key="SidebarNavFg"       Color="#666666"/>

    <!-- ── Cards / surfaces ──────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="CardBg"             Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBorder"         Color="#E0E0E0"/>
    <Color            x:Key="CardShadowColor"   >#000000</Color>

    <!-- ── Text ──────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="PrimaryText"        Color="#1A1A1A"/>
    <SolidColorBrush x:Key="SubText"            Color="#666666"/>
    <SolidColorBrush x:Key="MutedText"          Color="#999999"/>

    <!-- ── DataGrid ──────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="GridRowBg"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="GridAltRowBg"       Color="#FAFAFA"/>
    <SolidColorBrush x:Key="GridHeaderBg"       Color="#F9F9F9"/>
    <SolidColorBrush x:Key="GridHeaderFg"       Color="#444444"/>
    <SolidColorBrush x:Key="GridBorder"         Color="#E5E5E5"/>
    <SolidColorBrush x:Key="GridFg"             Color="#1A1A1A"/>

    <!-- ── Inputs ────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="InputBg"            Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputBorder"        Color="#D1D1D1"/>
    <SolidColorBrush x:Key="InputFg"            Color="#1A1A1A"/>

    <!-- ── Tabs ──────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TabFg"              Color="#666666"/>
    <SolidColorBrush x:Key="TabSelectedFg"      Color="#0078D4"/>
    <SolidColorBrush x:Key="TabSelectedBorder"  Color="#0078D4"/>
    <SolidColorBrush x:Key="TabControlBg"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TabHoverBg"         Color="#F0F0F0"/>

    <!-- ── Code / JSON ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="CodeBg"             Color="#1E1E1E"/>
    <SolidColorBrush x:Key="CodeFg"             Color="#D4D4D4"/>

    <!-- ── KPI ───────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="StatCountFg"        Color="#1A1A1A"/>
    <SolidColorBrush x:Key="KpiHeaderBg"        Color="#0078D4"/>
    <SolidColorBrush x:Key="KpiHeaderFg"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="KpiValueFg"         Color="#0078D4"/>
    <SolidColorBrush x:Key="KpiCardBorder"      Color="#E0E0E0"/>

    <!-- ── Semantic ──────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="SeparatorFg"           Color="#E5E5E5"/>
    <SolidColorBrush x:Key="StatusLabelFg"         Color="#666666"/>
    <SolidColorBrush x:Key="InfoBoxBg"             Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CopyBtnBg"             Color="#F5F5F5"/>
    <SolidColorBrush x:Key="CopyBtnBorder"         Color="#D1D1D1"/>

    <!-- ── Quick-fetch chips ─────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="QuickFetchAchBg"       Color="#EFF6FF"/>
    <SolidColorBrush x:Key="QuickFetchAchBorder"   Color="#BFDBFE"/>
    <SolidColorBrush x:Key="QuickFetchAchFg"       Color="#1D4ED8"/>
    <SolidColorBrush x:Key="QuickFetchCcBg"        Color="#EEF8FF"/>
    <SolidColorBrush x:Key="QuickFetchCcBorder"    Color="#BAE3FF"/>
    <SolidColorBrush x:Key="QuickFetchCcFg"        Color="#0067C0"/>

    <!-- ── Cards / tiles ─────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="CardBorder2"        Color="#E5E5E5"/>
    <SolidColorBrush x:Key="TileCardBg"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PanelTitleFg"       Color="#1A1A1A"/>

    <!-- ── JSON formatter ────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="JsonInputBg"              Color="#F9F9F9"/>
    <SolidColorBrush x:Key="JsonInputBorder"          Color="#D1D1D1"/>
    <SolidColorBrush x:Key="JsonOutputGreenBg"        Color="#F0FDF4"/>
    <SolidColorBrush x:Key="JsonOutputGreenBorder"    Color="#22C55E"/>
    <SolidColorBrush x:Key="JsonOutputYellowBg"       Color="#FFFBEB"/>
    <SolidColorBrush x:Key="JsonOutputYellowBorder"   Color="#F59E0B"/>

    <!-- ── Labels ────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="LabelFg"            Color="#1A1A1A"/>
    <SolidColorBrush x:Key="SubLabelFg"         Color="#666666"/>
    <SolidColorBrush x:Key="HintFg"             Color="#999999"/>

    <!-- ── Info banner ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="InfoBannerBg"       Color="#EEF8FF"/>
    <SolidColorBrush x:Key="InfoBannerBorder"   Color="#0078D4"/>
    <SolidColorBrush x:Key="InfoBannerTitleFg"  Color="#0067C0"/>
    <SolidColorBrush x:Key="InfoBannerNumFg"    Color="#0078D4"/>
    <SolidColorBrush x:Key="InfoBannerTextFg"   Color="#444444"/>

    <!-- ── Search card ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="SearchCardBg"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SearchCardBorder"   Color="#E0E0E0"/>

    <!-- ── Logo badge ────────────────────────────────────────────────────── -->
    <LinearGradientBrush x:Key="LogoBadgeBg" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0078D4" Offset="0"/>
        <GradientStop Color="#0067C0" Offset="1"/>
    </LinearGradientBrush>

    <!-- ── Section headers ───────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="EmailSectionBg"     Color="#EFF6FF"/>
    <SolidColorBrush x:Key="EmailSectionBorder" Color="#BFDBFE"/>
    <SolidColorBrush x:Key="EmailSectionFg"     Color="#1D4ED8"/>

    <SolidColorBrush x:Key="TxnSectionBg"       Color="#EEF8FF"/>
    <SolidColorBrush x:Key="TxnSectionBorder"   Color="#0078D4"/>
    <SolidColorBrush x:Key="TxnSectionFg"       Color="#0067C0"/>

    <SolidColorBrush x:Key="DisbSectionBg"      Color="#F0FDF4"/>
    <SolidColorBrush x:Key="DisbSectionBorder"  Color="#22C55E"/>
    <SolidColorBrush x:Key="DisbSectionFg"      Color="#166534"/>

    <!-- ── Webhook panel ─────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="WebhookPanelBg"       Color="#F0FDF4"/>
    <SolidColorBrush x:Key="WebhookPanelBorder"   Color="#22C55E"/>
    <SolidColorBrush x:Key="WebhookConfigBg"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="WebhookConfigBorder"  Color="#22C55E"/>
    <SolidColorBrush x:Key="WebhookConfigFg"      Color="#1A1A1A"/>

    <!-- ── Info strips ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="InfoStripGreenBorder"     Color="#22C55E"/>
    <SolidColorBrush x:Key="InfoStripBlueBorder"      Color="#0078D4"/>
    <SolidColorBrush x:Key="InfoStripGreenFg"         Color="#1A1A1A"/>
    <SolidColorBrush x:Key="InfoStripBlueFg"          Color="#1A1A1A"/>
    <SolidColorBrush x:Key="InfoStripGreenBtnBg"      Color="#F0FDF4"/>
    <SolidColorBrush x:Key="InfoStripGreenBtnHover"   Color="#DCFCE7"/>
    <SolidColorBrush x:Key="InfoStripBlueBtnBg"       Color="#EEF8FF"/>
    <SolidColorBrush x:Key="InfoStripBlueBtnHover"    Color="#DBEAFE"/>
    <SolidColorBrush x:Key="InfoStripBlueBtnBg2"      Color="#EEF8FF"/>

    <!-- ── Orange / amber ────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="OrangePanelBg"       Color="#FFFBEB"/>
    <SolidColorBrush x:Key="OrangePanelBorder"   Color="#F59E0B"/>
    <SolidColorBrush x:Key="OrangePanelFg"       Color="#1A1A1A"/>

    <!-- ── DB config ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="DbConfigBg"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DbConfigBlueBg"      Color="#EEF8FF"/>
    <SolidColorBrush x:Key="DbConfigBorder"      Color="#E0E0E0"/>
    <SolidColorBrush x:Key="DbConfigBlueBorder"  Color="#0078D4"/>

    <!-- ── Summary bar ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="SummaryBarBg"        Color="#F9F9F9"/>
    <SolidColorBrush x:Key="SummaryBarBorder"    Color="#E0E0E0"/>

    <!-- ── Test row states ───────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TestRowPassBg"       Color="#F0FDF4"/>
    <SolidColorBrush x:Key="TestRowFailBg"       Color="#FFF1F2"/>
    <SolidColorBrush x:Key="TestRowRunningBg"    Color="#FFFBEB"/>

    <!-- ── Surface / convenience ─────────────────────────────────────────── -->
    <SolidColorBrush x:Key="DarkSurface"         Color="#F5F5F5"/>
    <SolidColorBrush x:Key="DarkSurface2"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DarkBorder"          Color="#E5E5E5"/>
    <SolidColorBrush x:Key="DarkText"            Color="#1A1A1A"/>
    <SolidColorBrush x:Key="DarkSubText"         Color="#666666"/>
    <SolidColorBrush x:Key="DarkAccent"          Color="#0078D4"/>
    <SolidColorBrush x:Key="DarkBtnBg"           Color="#F5F5F5"/>
    <SolidColorBrush x:Key="DarkBtnBgHover"      Color="#EBEBEB"/>
    <SolidColorBrush x:Key="DarkScrollBg"        Color="#F3F3F3"/>

    <!-- ── Env toggle ────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="EnvBtnInactiveBg"     Color="#F5F5F5"/>
    <SolidColorBrush x:Key="EnvBtnInactiveBorder" Color="#D1D1D1"/>
    <SolidColorBrush x:Key="EnvBtnInactiveFg"     Color="#1A1A1A"/>

    <SolidColorBrush x:Key="FgDefault"           Color="#1A1A1A"/>


    <!-- ═══════════════════════════════════════════════════════════════════
         SCROLLBAR — Win11 thin auto-hide style, appears on hover
         ═══════════════════════════════════════════════════════════════════ -->

    <Style x:Key="Win11ScrollThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop"             Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="Bd" Background="#ADADAD" CornerRadius="3"
                            Margin="2,0"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#737373"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#0078D4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Win11ScrollPageBtn" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop"             Value="False"/>
        <Setter Property="Focusable"             Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="Win11VScrollBar" TargetType="ScrollBar">
        <Border Background="Transparent" Width="6" Padding="0,4">
            <Track x:Name="PART_Track" IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource Win11ScrollPageBtn}" Command="ScrollBar.PageUpCommand"/>
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource Win11ScrollThumb}"/>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource Win11ScrollPageBtn}" Command="ScrollBar.PageDownCommand"/>
                </Track.IncreaseRepeatButton>
            </Track>
        </Border>
    </ControlTemplate>

    <ControlTemplate x:Key="Win11HScrollBar" TargetType="ScrollBar">
        <Border Background="Transparent" Height="6" Padding="4,0">
            <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource Win11ScrollPageBtn}" Command="ScrollBar.PageLeftCommand"/>
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource Win11ScrollThumb}"/>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource Win11ScrollPageBtn}" Command="ScrollBar.PageRightCommand"/>
                </Track.IncreaseRepeatButton>
            </Track>
        </Border>
    </ControlTemplate>

    <Style TargetType="ScrollBar">
        <Setter Property="OverridesDefaultStyle"  Value="True"/>
        <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Width"    Value="6"/>
                <Setter Property="Template" Value="{StaticResource Win11VScrollBar}"/>
            </Trigger>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height"   Value="6"/>
                <Setter Property="Template" Value="{StaticResource Win11HScrollBar}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="CanContentScroll"            Value="False"/>
        <Setter Property="PanningMode"                 Value="VerticalOnly"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ScrollContentPresenter Grid.Column="0" Grid.Row="0"
                                                CanContentScroll="{TemplateBinding CanContentScroll}"/>
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Grid.Column="1" Grid.Row="0" Orientation="Vertical"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                   Grid.Column="0" Grid.Row="1" Orientation="Horizontal"
                                   Value="{TemplateBinding HorizontalOffset}"
                                   Maximum="{TemplateBinding ScrollableWidth}"
                                   ViewportSize="{TemplateBinding ViewportWidth}"
                                   Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ═══════════════════════════════════════════════════════════════════
         CONTROL STYLES — Windows 11 Fluent Design Light
         Font: Segoe UI Variable · Radius: 4px controls / 8px cards
         ═══════════════════════════════════════════════════════════════════ -->

    <Style TargetType="Window">
        <Setter Property="Foreground" Value="#1A1A1A"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"/>
        <Setter Property="FontSize"   Value="14"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground"                     Value="#1A1A1A"/>
        <Setter Property="FontFamily"                     Value="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode"  Value="ClearType"/>
    </Style>

    <!-- TextBox — Win11 rounded 4px, subtle bottom-border on normal, full on focus -->
    <Style TargetType="TextBox">
        <Setter Property="Background"      Value="#FFFFFF"/>
        <Setter Property="Foreground"      Value="#1A1A1A"/>
        <Setter Property="BorderBrush"     Value="#D1D1D1"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CaretBrush"      Value="#0078D4"/>
        <Setter Property="SelectionBrush"  Value="#0078D4"/>
        <Setter Property="SelectionOpacity" Value="0.3"/>
        <Setter Property="FontFamily"      Value="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"/>
        <Setter Property="Padding"         Value="8,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Padding="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      CanContentScroll="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D4"/>
                            <Setter TargetName="Bd" Property="BorderThickness" Value="1,1,1,2"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#888888"/>
                        </Trigger>
                        <Trigger Property="IsReadOnly" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#F9F9F9"/>
                            <Setter Property="Foreground"                 Value="#666666"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="Background"      Value="#FFFFFF"/>
        <Setter Property="Foreground"      Value="#1A1A1A"/>
        <Setter Property="BorderBrush"     Value="#D1D1D1"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CaretBrush"      Value="#0078D4"/>
        <Setter Property="FontFamily"      Value="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"/>
        <Setter Property="Padding"         Value="8,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Padding="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D4"/>
                            <Setter TargetName="Bd" Property="BorderThickness" Value="1,1,1,2"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#888888"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox — Win11 4px radius, clean dropdown with 8px shadow -->
    <Style TargetType="ComboBox">
        <Setter Property="Background"  Value="#FFFFFF"/>
        <Setter Property="Foreground"  Value="#1A1A1A"/>
        <Setter Property="BorderBrush" Value="#D1D1D1"/>
        <Setter Property="FontFamily"  Value="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="1"
                                      Focusable="False"
                                      IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay,
                                                  RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="TBd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Win11 chevron -->
                                            <TextBlock Grid.Column="1"
                                                       Text="&#xE70D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="10" Foreground="#666666"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TBd" Property="Background"  Value="#F5F5F5"/>
                                            <Setter TargetName="TBd" Property="BorderBrush" Value="#888888"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="TBd" Property="BorderBrush" Value="#0078D4"/>
                                            <Setter TargetName="TBd" Property="BorderThickness" Value="1,1,1,2"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter x:Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          Margin="10,0,30,0"
                                          VerticalAlignment="Center"/>
                        <TextBox x:Name="PART_EditableTextBox"
                                 Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}"
                                 Margin="8,0,30,0" VerticalAlignment="Center"
                                 Background="Transparent" Foreground="#1A1A1A"
                                 BorderThickness="0"/>
                        <Popup x:Name="Popup" Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True" Focusable="False"
                               PopupAnimation="Fade">
                            <Grid x:Name="DropDown"
                                  MinWidth="{TemplateBinding ActualWidth}"
                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border Background="#FFFFFF" BorderBrush="#E0E0E0"
                                        BorderThickness="1" CornerRadius="8" Padding="4">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="24" ShadowDepth="4"
                                                          Opacity="0.14" Color="#000000"/>
                                    </Border.Effect>
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="ContentSite"          Property="Visibility" Value="Hidden"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#1A1A1A"/>
        <Setter Property="Padding"    Value="10,7"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}" Margin="0,1">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#F0F0F0"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#CCE4FF"/>
                            <Setter Property="Foreground"                 Value="#003E92"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background"      Value="#FFFFFF"/>
        <Setter Property="BorderBrush"     Value="#E5E5E5"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- TabItem — Win11 underline indicator style -->
    <Style TargetType="TabItem">
        <Setter Property="Background"  Value="Transparent"/>
        <Setter Property="Foreground"  Value="#666666"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Padding"     Value="16,10"/>
        <Setter Property="FontSize"    Value="14"/>
        <Setter Property="FontFamily"  Value="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="TabBorder" Background="Transparent"
                            BorderThickness="0,0,0,2" BorderBrush="Transparent"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter ContentSource="Header"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                          TextBlock.FontWeight="Medium"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="#0078D4"/>
                            <Setter Property="Foreground" Value="#0078D4"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="#1A1A1A"/>
                            <Setter TargetName="TabBorder" Property="Background" Value="#F0F0F0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Button — Win11 subtle fill, 4px radius -->
    <Style TargetType="Button">
        <Setter Property="Background"      Value="#F5F5F5"/>
        <Setter Property="Foreground"      Value="#1A1A1A"/>
        <Setter Property="BorderBrush"     Value="#D1D1D1"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Padding"         Value="16,6"/>
        <Setter Property="FontFamily"      Value="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"/>
        <Setter Property="FontSize"        Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"  Value="#EBEBEB"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#ADADAD"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"  Value="#E0E0E0"/>
                            <Setter Property="Foreground" Value="#444444"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.40"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- PrimaryButton — Win11 accent fill (#0078D4) -->
    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background"  Value="#0078D4"/>
        <Setter Property="Foreground"  Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#0067C0"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="#1A1A1A"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"/>
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="#1A1A1A"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"/>
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="Background"  Value="#FFFFFF"/>
        <Setter Property="Foreground"  Value="#1A1A1A"/>
        <Setter Property="BorderBrush" Value="#D1D1D1"/>
        <Setter Property="FontFamily"  Value="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"/>
    </Style>

    <!-- DataGrid — Win11 clean table, subtle alt rows -->
    <Style TargetType="DataGrid">
        <Setter Property="Background"               Value="#FFFFFF"/>
        <Setter Property="Foreground"               Value="#1A1A1A"/>
        <Setter Property="BorderBrush"              Value="#E5E5E5"/>
        <Setter Property="BorderThickness"          Value="0"/>
        <Setter Property="RowBackground"            Value="#FFFFFF"/>
        <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#F0F0F0"/>
        <Setter Property="VerticalGridLinesBrush"   Value="Transparent"/>
        <Setter Property="ColumnHeaderHeight"       Value="36"/>
        <Setter Property="RowHeight"                Value="38"/>
        <Setter Property="FontFamily"               Value="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"/>
        <Setter Property="FontSize"                 Value="13"/>
        <Setter Property="SelectionUnit"            Value="FullRow"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background"      Value="#F9F9F9"/>
        <Setter Property="Foreground"      Value="#444444"/>
        <Setter Property="BorderBrush"     Value="#E5E5E5"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding"         Value="12,0"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="FontFamily"      Value="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"/>
        <Setter Property="Height"          Value="36"/>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Foreground"      Value="#1A1A1A"/>
        <Setter Property="BorderBrush"     Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="4,0"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#CCE4FF"/>
                <Setter Property="Foreground" Value="#003E92"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Background"      Value="#FFFFFF"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin"          Value="0"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#E5F3FF"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F0F0F0"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="#1A1A1A"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"/>
    </Style>

    <Style TargetType="GroupBox">
        <Setter Property="Foreground"  Value="#1A1A1A"/>
        <Setter Property="BorderBrush" Value="#E0E0E0"/>
        <Setter Property="FontFamily"  Value="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"/>
    </Style>

    <!-- ToolTip — Win11 Fluent tooltip: white bg, 8px radius, soft shadow -->
    <Style TargetType="ToolTip">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="0"/>
        <Setter Property="HasDropShadow"   Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="#FFFFFF" CornerRadius="8"
                            Padding="14,10" BorderBrush="#E0E0E0" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="28" ShadowDepth="4"
                                              Opacity="0.18" Color="#000000"/>
                        </Border.Effect>
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="#1A1A1A" FontSize="13"
                                   FontFamily="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"
                                   TextWrapping="Wrap" MaxWidth="440"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ContextMenu">
        <Setter Property="Background"  Value="#FFFFFF"/>
        <Setter Property="Foreground"  Value="#1A1A1A"/>
        <Setter Property="BorderBrush" Value="#E0E0E0"/>
        <Setter Property="FontFamily"  Value="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="#FFFFFF" BorderBrush="#E0E0E0"
                            BorderThickness="1" CornerRadius="8" Padding="4">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="28" ShadowDepth="4"
                                              Opacity="0.16" Color="#000000"/>
                        </Border.Effect>
                        <ItemsPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#1A1A1A"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"/>
        <Setter Property="Padding"    Value="12,7"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}" Margin="0,1">
                        <ContentPresenter ContentSource="Header"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#F0F0F0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Height="1" Background="#E5E5E5" Margin="8,3"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
