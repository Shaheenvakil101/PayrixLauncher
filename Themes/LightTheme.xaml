    <SolidColorBrush x:Key="GridBorder"         Color="#E5E5EA"/>
    <SolidColorBrush x:Key="GridFg"             Color="#1D1D1F"/>

    <!-- ── Inputs ────────────────────────────────────────────────────────── -->
