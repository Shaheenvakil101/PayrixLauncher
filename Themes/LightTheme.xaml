    <SolidColorBrush x:Key="KpiHeaderBg"        Color="#1D1D1F"/>
    <SolidColorBrush x:Key="KpiHeaderFg"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="KpiValueFg"         Color="#007AFF"/>
    <SolidColorBrush x:Key="KpiCardBorder"      Color="#E5E5EA"/>

    <!-- ── Semantic ──────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="SeparatorFg"           Color="#E5E5EA"/>
