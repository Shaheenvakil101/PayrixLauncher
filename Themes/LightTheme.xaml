    <SolidColorBrush x:Key="QuickFetchAchBorder"   Color="#D2D2D7"/>
    <SolidColorBrush x:Key="QuickFetchAchFg"       Color="#5856D6"/>
    <SolidColorBrush x:Key="QuickFetchCcBg"        Color="#F5F5F7"/>
    <SolidColorBrush x:Key="QuickFetchCcBorder"    Color="#D2D2D7"/>
    <SolidColorBrush x:Key="QuickFetchCcFg"        Color="#007AFF"/>

    <!-- ── Cards / tiles ─────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="CardBorder2"        Color="#E5E5EA"/>
    <SolidColorBrush x:Key="TileCardBg"         Color="#FFFFFF"/>
